---
const year = new Date().getFullYear();
---

<footer class="lfoot">
    <div class="wrap lfoot-inner">
        <div class="lfoot-brand">
            <div class="lfoot-logo">
                <span class="lfoot-mark">Techstars</span>
                <span class="lfoot-place">Belfast</span>
            </div>
            <p class="lfoot-tag">An official Techstars Startup Community Partnership, delivered with Queen's University Belfast and Ormeau Labs.</p>
        </div>

        <div class="lfoot-cols">
            <nav class="lfoot-links" aria-label="Explore">
                <h4>Explore</h4>
                <a href="/events">Events</a>
                <a href="/programmes">Founder Catalyst</a>
                <a href="/sprints">Sprints</a>
                <a href="/about">About</a>
            </nav>
            <nav class="lfoot-links" aria-label="Connect">
                <h4>Connect</h4>
                <a href="/partners">Partner with us</a>
                <a href="https://www.linkedin.com/showcase/techstars-belfast" target="_blank" rel="noopener">LinkedIn</a>
                <a href="https://www.techstars.com/blog/advice/mentor-manifesto" target="_blank" rel="noopener">Mentor Manifesto</a>
            </nav>
        </div>
    </div>
    <div class="wrap lfoot-bottom">
        <span>&copy; {year} Techstars Belfast. All rights reserved.</span>
        <span class="lfoot-legal">
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
        </span>
        <span class="lfoot-mono">Build here. Connect everywhere.</span>
    </div>
</footer>

<style>
    .lfoot { border-top: 1px solid var(--line); padding: 4rem 0 2.5rem; background: var(--bg-subtle); }
    .lfoot-inner { display: flex; justify-content: space-between; gap: 3rem; flex-wrap: wrap; margin-bottom: 3rem; }
    .lfoot-brand { max-width: 420px; }
    .lfoot-logo { display: flex; align-items: baseline; gap: 0.4rem; margin-bottom: 0.75rem; }
    .lfoot-mark { font-weight: 800; font-size: 1.15rem; letter-spacing: -0.03em; }
    .lfoot-place { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); font-weight: 700; }
    .lfoot-tag { font-size: 0.92rem; color: var(--ink-muted); line-height: 1.6; }
    .lfoot-cols { display: flex; gap: 4rem; flex-wrap: wrap; }
    .lfoot-links { display: flex; flex-direction: column; gap: 0.75rem; }
    .lfoot-links h4 { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--ink-muted); margin-bottom: 0.25rem; }
    .lfoot-links a { font-size: 0.95rem; color: var(--ink-soft); transition: color var(--t); }
    .lfoot-links a:hover { color: var(--accent); }
    .lfoot-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 2rem; border-top: 1px solid var(--line); flex-wrap: wrap; gap: 0.75rem; }
    .lfoot-bottom span { font-size: 0.8rem; color: var(--ink-muted); }
    .lfoot-legal { display: flex; gap: 1.25rem; }
    .lfoot-legal a { transition: color var(--t); }
    .lfoot-legal a:hover { color: var(--accent); }
    .lfoot-mono { font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.1em; }
    @media (max-width: 600px) { .lfoot-inner { flex-direction: column; gap: 2rem; } }
</style>
