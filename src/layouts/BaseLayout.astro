---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title?: string;
    description?: string;
    ogImage?: string;
    hideHeader?: boolean;
}

const SITE_NAME = "Techstars Belfast";
const SITE_TAGLINE = "Techstars Belfast - global mindset from day one";
const DEFAULT_DESCRIPTION = "Techstars Belfast is a founder community and pre-accelerator in Northern Ireland. Backed by Coinbase, Stripe, and ElevenLabs.";

const {
    title,
    description = DEFAULT_DESCRIPTION,
    ogImage = "/images/founders1.jpg",
    hideHeader = false,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE_NAME}` : SITE_TAGLINE;
const ogTitle = title ? `${title} | ${SITE_NAME}` : SITE_TAGLINE;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://techstarsbelfast.com").href;
const ogImageUrl = new URL(ogImage, Astro.site ?? "https://techstarsbelfast.com").href;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content={description}>
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl}>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest" defer></script>

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE_NAME}>
    <meta property="og:title" content={ogTitle}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:image" content={ogImageUrl}>
    <meta property="og:image:alt" content={ogTitle}>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content={ogTitle}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImageUrl}>
</head>
<body>
    {!hideHeader && <Header />}
    
    <main>
        <slot />
    </main>
    
    <Footer />
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }
        });
        // Also try immediately in case DOM is already loaded
        if (document.readyState === 'complete' || document.readyState === 'interactive') {
            setTimeout(() => {
                if (typeof lucide !== 'undefined') {
                    lucide.createIcons();
                }
            }, 100);
        }
    </script>
</body>
</html>
