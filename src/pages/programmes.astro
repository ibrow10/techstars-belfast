---
import BaseLayout from '../layouts/BaseLayout.astro';

const gives = [
    'Weekly masterclasses from Techstars leaders and operators',
    '1:1 mentor time with founders, operators and investors',
    'Pitch coaching until your story actually lands',
    'A global cohort that holds you to it',
];

const facts = [
    { k: 'Format', v: '10 weeks, part-time, virtual' },
    { k: 'Equity', v: 'None. Zero taken.' },
    { k: 'Cost', v: 'Free to selected founders' },
    { k: 'Runs', v: 'Sep – Nov 2026' },
];
---

<BaseLayout title="Founder Catalyst" description="A selective Techstars pre-accelerator for Northern Ireland's founders. 10 weeks, global cohort, no equity.">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Founder Catalyst · Techstars</p>
            <h1>Want to succeed?<br /><span class="accent">Apply.</span></h1>
            <p class="lead hero-lead">
                A selective Techstars pre-accelerator for founders building from Northern Ireland.
                Ten weeks that take you from early traction to fundable. It's the real thing.
            </p>
            <div class="hero-ctas">
                <a href="#apply" class="btn btn--accent">Apply now</a>
                <a href="/sprints" class="btn btn--ghost">Not ready? Start with a sprint</a>
            </div>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-143.jpg" alt="A Techstars speaker presenting to founders in Belfast" class="hero-photo" />
        </div>
    </section>

    <!-- FACTS -->
    <section class="facts">
        <div class="wrap facts-inner">
            {facts.map(f => (
                <div class="fact">
                    <span class="fact-k">{f.k}</span>
                    <span class="fact-v">{f.v}</span>
                </div>
            ))}
        </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="section">
        <div class="wrap wrap--mid">
            <p class="eyebrow">What you get</p>
            <h2 class="gives-head">Everything that actually moves the needle.</h2>
            <ul class="gives">
                {gives.map(g => <li>{g}</li>)}
            </ul>
        </div>
    </section>

    <!-- PROOF LINE -->
    <section class="section--tight band">
        <div class="wrap wrap--mid">
            <p class="band-line">
                Delivered through Techstars — 10,000+ founders, 150+ countries, $130B+ in market cap.
                You're not joining a local programme. You're joining a global one, from here.
            </p>
        </div>
    </section>

    <!-- WHO -->
    <section class="section">
        <div class="wrap wrap--mid who-grid">
            <div>
                <p class="eyebrow">Who it's for</p>
                <h2 class="who-head">Builders, researchers, domain experts.</h2>
                <p class="lead who-body">
                    Past pure ideation. Some signal — pilots, users, a waitlist, early revenue.
                    Ambitious enough to build something that competes anywhere. If that's you, apply.
                </p>
            </div>
            <img src="/images/photos/pic-153.jpg" alt="Founders in a 1:1 mentoring conversation at Techstars Belfast" class="who-photo" loading="lazy" />
        </div>
    </section>

    <!-- APPLY -->
    <section id="apply" class="apply">
        <div class="wrap wrap--mid apply-inner">
            <h2>Applications are open.</h2>
            <p class="lead">Take the shot. Worst case, you sharpen your story. Best case, everything changes.</p>
            <a href="https://www.linkedin.com/showcase/techstars-belfast" class="btn btn--accent" target="_blank" rel="noopener">Apply now</a>
            <p class="apply-note">No equity. No cost. No tourists.</p>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 4rem; }
    .hero h1 { margin: 1.25rem 0 1.75rem; }
    .hero-lead { margin-bottom: 2.5rem; }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3.5rem; }

    .facts { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-subtle); }
    .facts-inner { display: grid; grid-template-columns: repeat(4, 1fr); }
    .fact { padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; border-left: 1px solid var(--line); }
    .fact:first-child { border-left: none; }
    .fact-k { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-muted); }
    .fact-v { font-size: 1.05rem; font-weight: 600; letter-spacing: -0.01em; }

    .gives-head, .who-head { margin: 0.75rem 0 2rem; }
    .gives { list-style: none; display: flex; flex-direction: column; gap: 0; }
    .gives li {
        font-size: 1.15rem;
        color: var(--ink-soft);
        padding: 1.1rem 0 1.1rem 2rem;
        border-bottom: 1px solid var(--line);
        position: relative;
    }
    .gives li:first-child { border-top: 1px solid var(--line); }
    .gives li::before { content: "→"; position: absolute; left: 0; color: var(--accent); font-weight: 700; }

    .band { background: var(--accent-soft); }
    .band-line { font-size: clamp(1.2rem, 2.4vw, 1.6rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.4; color: #0a3d24; }

    .who-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 3rem; align-items: center; }
    .who-body { max-width: 600px; }
    .who-photo { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 16px; }

    .apply { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .apply-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .apply h2 { color: var(--bg); }
    .apply .lead { color: rgba(255,255,255,0.72); max-width: 36ch; }
    .apply-note { font-family: var(--mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(255,255,255,0.5); margin-top: 0.5rem; }

    @media (max-width: 760px) {
        .facts-inner { grid-template-columns: repeat(2, 1fr); }
        .fact:nth-child(3) { border-left: none; }
        .fact { border-top: 1px solid var(--line); }
        .fact:nth-child(1), .fact:nth-child(2) { border-top: none; }
        .hero-ctas .btn { width: 100%; }
        .hero-photo { aspect-ratio: 16 / 10; }
        .who-grid { grid-template-columns: 1fr; gap: 2rem; }
    }
</style>
