---
import BaseLayout from '../layouts/BaseLayout.astro';

const applyUrl = 'https://www.techstars.com/techstars-founder-catalyst-global-fall-2026-program';


const benefits = [
    { icon: 'video', text: 'Weekly live masterclasses taught by Techstars leaders + experts' },
    { icon: 'wrench', text: 'Bonus workshops on practical founder execution' },
    { icon: 'users', text: '1:1 guidance and support from Techstars mentors/operators/investors' },
    { icon: 'mic', text: 'Weekly pitch coaching to sharpen your investor story' },
    { icon: 'gift', text: 'Exclusive perks (tools/credits/support)' },
    { icon: 'globe', text: 'A global peer cohort for accountability + collaboration' }
];

const tracks = [
    {
        number: '1',
        title: 'Masterclass Track',
        subtitle: 'Core founder build',
        description: 'A practical curriculum covering the fundamentals that make a startup investable:',
        items: [
            'Customer discovery → ICP → PMF evidence',
            'GTM wedge + experiments',
            'Metrics + traction narrative',
            'Financial model + runway logic',
            'Pitch + fundraising readiness'
        ]
    },
    {
        number: '2',
        title: 'Pitch Feedback Drop-ins',
        subtitle: 'Repetition loop',
        description: 'You pitch, get direct critique, iterate, and pitch again.',
        items: [
            'This is where founders compound fast: repetition + specific feedback beats "one perfect pitch workshop".'
        ]
    },
    {
        number: '3',
        title: 'Partner Workshops',
        subtitle: 'Operator-level help',
        description: 'Targeted sessions designed to make you execution-ready. (Examples from the Belfast track may include:)',
        items: [
            'Sales pipeline management using AI (HubSpot)',
            'AI infrastructure architecture (AWS)',
            'Investor pipeline management (Metal)'
        ]
    },
    {
        number: '4',
        title: 'Community Track',
        subtitle: 'Pattern recognition + ambition',
        description: 'Sessions that help you see what "great" looks like and how the game is played:',
        items: [
            'Fundraising fundamentals',
            'Unicorn journeys + founder mental models',
            'What great investors listen for (and what they ignore)'
        ]
    }
];

const curriculum = [
    {
        title: 'The Customer Playbook: Discovery → PMF',
        description: 'Run discovery properly, define your ICP, and prove the pain with evidence.'
    },
    {
        title: 'Forecasting for Success with Financial Modelling (Part 1)',
        description: 'Build a simple, investor-legible model: assumptions, unit economics logic, runway.'
    },
    {
        title: 'When to Scale and How Fast',
        description: 'Learn what scaling really means, and how to avoid premature burn.'
    },
    {
        title: 'Go-To-Market Foundations: picking the right first channel',
        description: 'Pick a wedge, design tests, avoid "spray and pray".'
    },
    {
        title: 'From Story to Stage: mastering the winning pitch',
        description: 'Problem, why now, why you, traction, model, ask. All tied to evidence.'
    },
    {
        title: 'Product: roadmapping, testing, prioritising & launching',
        description: 'Roadmap by hypothesis, not feature-wishlists.'
    },
    {
        title: 'The Magic of Metrics',
        description: 'Define the few numbers that matter and talk about traction credibly.'
    }
];

const outcomes = [
    'A clear ICP + problem statement backed by real customer conversations',
    'A tested GTM wedge (first channel + experiments + early signals)',
    'A simple financial model you can defend (assumptions, runway, key drivers)',
    'A product roadmap tied to hypotheses + learning milestones',
    'A metrics view (north star + a few traction indicators that make sense)',
    'A tight 3–4 minute pitch + narrative that matches the evidence',
    'A more professional investor pipeline approach (if fundraising is the right next step)'
];

const eligibility = [
    'Beyond ideation (moving toward product or growth)',
    'Pre- or post-revenue; if post-revenue, MRR up to $5k',
    'Raised no more than $400k external funding',
    'Traction signals encouraged (pilots, users, waitlist, pre-orders)',
    'Offered exclusively to founders from partner communities including Belfast'
];

const faqs = [
    {
        question: 'Is this in-person?',
        answer: "It's a virtual programme (part-time) running across 10 weeks."
    },
    {
        question: 'Do you take equity?',
        answer: 'No. Techstars notes there is no equity exchange in Founder Catalyst programmes.'
    },
    {
        question: "I'm a researcher. Can I apply if this isn't a fully formed startup yet?",
        answer: "If you're beyond pure ideation and can show real problem insight + evidence gathering (discovery, pilots, waitlist, early users), you're in the zone Techstars is looking for."
    },
    {
        question: 'Why should I trust this?',
        answer: "This is delivered through Techstars Belfast, a formal partnership between Ormeau Labs, Queen's, and Techstars. And Techstars has supported 10,000+ companies/founders globally."
    }
];
---

<BaseLayout title="Founder Catalyst">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Programmes</p>
            <h1>Founder <span class="accent">Catalyst.</span></h1>
            <p class="lead hero-lead">Build a fundable company from Belfast, with a global Techstars cohort.</p>
            <p class="muted hero-description">
                Founder Catalyst is a highly selective, 10-week, part-time virtual pre-accelerator designed to take you from early idea / early traction → clear customer, credible plan, fundable story.
            </p>

            <div class="facts">
                <div class="fact">
                    <span class="fact-k">Applications</span>
                    <span class="fact-v">Open now</span>
                </div>
                <div class="fact">
                    <span class="fact-k">Programme runs</span>
                    <span class="fact-v">September – November 2026</span>
                </div>
                <div class="fact">
                    <span class="fact-k">Demo Day</span>
                    <span class="fact-v">TBC</span>
                </div>
            </div>

            <div class="hero-ctas">
                <a href={applyUrl} class="btn btn--accent" target="_blank" rel="noopener">Apply now</a>
                <a href="/#newsletter" class="btn btn--ghost">Get the monthly email</a>
            </div>

            <div class="trust-bar">
                <span class="trust-item"><i data-lucide="check-circle"></i> Techstars-powered global programme</span>
                <span class="trust-item"><i data-lucide="check-circle"></i> No equity exchange</span>
                <span class="trust-item"><i data-lucide="check-circle"></i> Join a global cohort (Belfast + partner communities)</span>
            </div>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-143.jpg" alt="A Techstars speaker presenting to founders in Belfast" class="hero-photo" />
        </div>
    </section>

    <!-- NETWORK STATS -->
    <section class="proof">
        <div class="wrap proof-inner">
            <div class="proof-stat">
                <span class="proof-num">10,000+</span>
                <span class="proof-label">Founders in Techstars network</span>
            </div>
            <div class="proof-stat">
                <span class="proof-num">150+</span>
                <span class="proof-label">Countries represented</span>
            </div>
            <div class="proof-stat">
                <span class="proof-num">$130.6B+</span>
                <span class="proof-label">Market cap of Techstars companies</span>
            </div>
        </div>
    </section>

    <!-- WHY THIS MATTERS -->
    <section class="section">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Why this matters</p>
            <h2 class="section-head">Especially in Northern Ireland.</h2>
            <div class="why-content">
                <p>Techstars Belfast is a Startup Community Partnership built with <strong>Ormeau Labs</strong> and <strong>Queen's University Belfast</strong>, opening the door to Techstars' worldwide network of mentors, investors, tools, and programmes.</p>
                <p class="highlight-text">If you're building something ambitious here, Founder Catalyst is the fastest credible on-ramp into that global ecosystem.</p>
            </div>
        </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">What you get</p>
            <h2 class="section-head">The benefits founders actually care about.</h2>
            <p class="lead benefits-lead">You'll get a tight structure with weekly sessions and feedback loops, plus the credibility and reach of Techstars.</p>

            <div class="benefits-grid">
                {benefits.map(benefit => (
                    <div class="benefit-item">
                        <div class="benefit-icon">
                            <i data-lucide={benefit.icon}></i>
                        </div>
                        <span>{benefit.text}</span>
                    </div>
                ))}
            </div>

            <p class="benefits-translation">
                <strong>Translation:</strong> you leave with the artefacts customers and investors expect, not just "advice".
            </p>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <h2 class="section-head">How the programme works.</h2>

            <div class="tracks-grid">
                {tracks.map(track => (
                    <div class="card track-card">
                        <div class="track-number">{track.number}</div>
                        <div class="track-content">
                            <h3>{track.title}</h3>
                            <span class="track-subtitle">{track.subtitle}</span>
                            <p class="track-description">{track.description}</p>
                            <ul class="track-items">
                                {track.items.map(item => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CURRICULUM -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Curriculum</p>
            <h2 class="section-head">What you'll actually cover.</h2>

            <div class="curriculum-list">
                {curriculum.map((module, index) => (
                    <div class="curriculum-item">
                        <span class="curriculum-number">{String(index + 1).padStart(2, '0')}</span>
                        <div class="curriculum-content">
                            <h3>{module.title}</h3>
                            <p class="muted">{module.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- OUTCOMES -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Outcomes checklist</p>
            <h2 class="section-head">What you'll leave with.</h2>
            <p class="lead outcomes-lead">By the end, strong participants typically have:</p>

            <div class="outcomes-list">
                {outcomes.map(outcome => (
                    <div class="outcome-item">
                        <i data-lucide="check"></i>
                        <span>{outcome}</span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- SELECTION BAR -->
    <section class="section band">
        <div class="wrap wrap--mid">
            <p class="selection-intro">This is not for tourists.</p>
            <h2 class="band-head">The selection bar.</h2>

            <p class="selection-description">Techstars is looking for founders with deep problem insight, strong execution, resilience, and ambition to build scalable companies in meaningful markets.</p>

            <p class="criteria-label">Baseline criteria (from Techstars):</p>
            <ul class="eligibility-list">
                {eligibility.map(item => (
                    <li><i data-lucide="arrow-right"></i> {item}</li>
                ))}
            </ul>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section">
        <div class="wrap wrap--mid">
            <h2 class="section-head">FAQ</h2>

            <div class="faq-list">
                {faqs.map(faq => (
                    <div class="faq-item">
                        <h3>{faq.question}</h3>
                        <p class="muted">{faq.answer}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- FINAL CTA -->
    <section class="final-cta">
        <div class="wrap wrap--mid final-cta-inner">
            <p class="deadline-text">Applications are open now</p>
            <h2>Founder Catalyst returns for autumn 2026.</h2>

            <div class="cta-buttons">
                <a href={applyUrl} class="btn btn--accent" target="_blank" rel="noopener">Apply now</a>
                <a href="/#newsletter" class="btn btn--ghost-dark">Get the monthly email</a>
            </div>
            <p class="cta-note">One email a month, no spam.</p>
        </div>
    </section>
</BaseLayout>

<style>
    /* HERO */
    .hero { padding: 6rem 0 4rem; }
    .hero h1 { margin: 1.25rem 0 1.5rem; }
    .hero-lead { margin-bottom: 1.25rem; }
    .hero-description { max-width: 640px; margin-bottom: 2.5rem; line-height: 1.65; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3.5rem; }

    .facts {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        background: var(--bg-subtle);
        border: 1px solid var(--line);
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 2.5rem;
    }
    .fact { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; border-left: 1px solid var(--line); }
    .fact:first-child { border-left: none; }
    .fact-k { font-family: var(--mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-muted); }
    .fact-v { font-size: 1rem; font-weight: 600; letter-spacing: -0.01em; color: var(--ink); }

    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }

    .trust-bar { display: flex; gap: 2rem; flex-wrap: wrap; padding-top: 1.5rem; border-top: 1px solid var(--line); }
    .trust-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--mono);
        font-size: 0.78rem;
        color: var(--ink-muted);
    }
    .trust-item i { width: 16px; height: 16px; color: var(--accent); flex-shrink: 0; }

    /* STATS STRIP */
    .proof { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-subtle); }
    .proof-inner { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; padding: 3rem 1.5rem; }
    .proof-stat { display: flex; flex-direction: column; gap: 0.4rem; }
    .proof-num { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 800; letter-spacing: -0.03em; color: var(--ink); }
    .proof-label { font-size: 0.85rem; color: var(--ink-muted); line-height: 1.4; }

    /* SECTION HEADS */
    .section-head { margin: 0.75rem 0 2rem; }

    /* WHY THIS MATTERS */
    .why-content { border-left: 3px solid var(--accent); padding-left: 2rem; max-width: 680px; }
    .why-content p { font-size: 1.1rem; color: var(--ink-soft); line-height: 1.7; margin-bottom: 1.5rem; }
    .why-content p:last-child { margin-bottom: 0; }
    .why-content strong { color: var(--ink); }
    .highlight-text { color: var(--ink); font-size: 1.2rem; font-weight: 600; }

    /* WHAT YOU GET */
    .benefits-lead { margin-bottom: 2.5rem; }
    .benefits-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
        margin-bottom: 2.5rem;
    }
    .benefit-item { display: flex; align-items: flex-start; gap: 1rem; }
    .benefit-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-soft);
        border-radius: 10px;
        flex-shrink: 0;
        color: var(--accent);
    }
    .benefit-icon i { width: 18px; height: 18px; }
    .benefit-item span { font-size: 0.98rem; color: var(--ink-soft); line-height: 1.55; padding-top: 0.5rem; }

    .benefits-translation {
        background: var(--bg-subtle);
        border-radius: 12px;
        padding: 1.5rem 1.75rem;
        font-size: 1rem;
        color: var(--ink-soft);
        line-height: 1.6;
    }
    .benefits-translation strong { color: var(--accent); }

    /* HOW IT WORKS */
    .tracks-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .track-card { display: flex; gap: 1.5rem; padding: 2rem; }
    .track-number { font-family: var(--mono); font-size: 2rem; font-weight: 700; color: var(--accent); line-height: 1; flex-shrink: 0; }
    .track-content h3 { font-size: 1.2rem; margin-bottom: 0.35rem; }
    .track-subtitle {
        display: block;
        font-family: var(--mono);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink-muted);
        margin-bottom: 1rem;
    }
    .track-description { font-size: 0.95rem; color: var(--ink-soft); line-height: 1.55; margin-bottom: 1rem; }
    .track-items { list-style: none; padding: 0; }
    .track-items li {
        font-size: 0.9rem;
        color: var(--ink-muted);
        padding-left: 1.25rem;
        position: relative;
        margin-bottom: 0.5rem;
        line-height: 1.5;
    }
    .track-items li::before { content: "→"; position: absolute; left: 0; color: var(--accent); font-weight: 700; }

    /* CURRICULUM */
    .curriculum-list { display: flex; flex-direction: column; }
    .curriculum-item {
        display: flex;
        gap: 1.75rem;
        align-items: flex-start;
        padding: 1.4rem 0;
        border-bottom: 1px solid var(--line);
    }
    .curriculum-item:first-child { border-top: 1px solid var(--line); }
    .curriculum-number { font-family: var(--mono); font-size: 0.85rem; color: var(--accent); flex-shrink: 0; padding-top: 0.3rem; }
    .curriculum-content h3 { font-size: 1.05rem; margin-bottom: 0.35rem; }
    .curriculum-content p { font-size: 0.95rem; line-height: 1.55; }

    /* OUTCOMES */
    .outcomes-lead { margin-bottom: 2rem; }
    .outcomes-list { display: flex; flex-direction: column; }
    .outcome-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        padding: 1rem 0;
        border-bottom: 1px solid var(--line);
    }
    .outcome-item:first-child { border-top: 1px solid var(--line); }
    .outcome-item i { width: 20px; height: 20px; color: var(--accent); flex-shrink: 0; margin-top: 3px; }
    .outcome-item span { font-size: 1rem; color: var(--ink-soft); line-height: 1.55; }

    /* SELECTION BAR */
    .band { background: var(--accent-soft); }
    .selection-intro { font-family: var(--mono); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); margin-bottom: 1rem; }
    .band-head { color: #0a3d24; margin-bottom: 1.5rem; }
    .selection-description { font-size: 1.15rem; font-weight: 500; color: #0a3d24; line-height: 1.6; margin-bottom: 2rem; max-width: 640px; }
    .criteria-label { font-family: var(--mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: #0a3d24; margin-bottom: 1.25rem; }
    .eligibility-list { list-style: none; padding: 0; }
    .eligibility-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        font-size: 1rem;
        color: #0a3d24;
        margin-bottom: 0.75rem;
        line-height: 1.55;
    }
    .eligibility-list i { width: 16px; height: 16px; color: var(--accent); flex-shrink: 0; margin-top: 4px; }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; }
    .faq-item { padding: 1.75rem 0; border-top: 1px solid var(--line); }
    .faq-item:last-child { border-bottom: 1px solid var(--line); }
    .faq-item h3 { font-size: 1.1rem; margin-bottom: 0.6rem; line-height: 1.4; }
    .faq-item p { font-size: 0.98rem; line-height: 1.65; }

    /* FINAL CTA */
    .final-cta { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .final-cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .deadline-text { font-family: var(--mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent-bright); }
    .final-cta h2 { color: var(--bg); }
    .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 0.5rem; }
    .btn--ghost-dark { background: transparent; color: #fff; border-color: rgba(255, 255, 255, 0.3); }
    .btn--ghost-dark:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.5); }
    .cta-note { font-family: var(--mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: rgba(255, 255, 255, 0.5); margin-top: 0.25rem; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
        .benefits-grid { grid-template-columns: 1fr; }
        .tracks-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 760px) {
        .hero-photo { aspect-ratio: 16 / 10; }
        .facts { grid-template-columns: 1fr; }
        .fact { border-left: none; border-top: 1px solid var(--line); }
        .fact:first-child { border-top: none; }
        .proof-inner { grid-template-columns: 1fr; gap: 1.5rem; }
        .trust-bar { flex-direction: column; gap: 0.75rem; }
        .track-card { flex-direction: column; gap: 1rem; }
        .why-content { padding-left: 1.25rem; }
    }

    @media (max-width: 600px) {
        .hero-ctas .btn, .cta-buttons .btn { width: 100%; text-align: center; }
    }
</style>
