---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
    '10,000+ founders in the global Techstars network',
    '$130.6B+ market cap of Techstars companies',
    '150+ countries represented'
];

const whyPartnerColumns = [
    {
        audience: 'For corporates',
        description: 'Early talent pipeline. Pre-IPO startup access. Credible AI-native positioning your customers and recruits will notice.'
    },
    {
        audience: 'For investors',
        description: 'Deal flow at the earliest possible stage. Curated intros. Co-invest signals from a global Techstars network.'
    },
    {
        audience: 'For universities & public sector',
        description: 'Translate research into commercial outcomes. Deliver entrepreneurship outputs that funders can measure.'
    }
];

const eventFormats = [
    'Founder Night (short talks + networking)',
    'AMA / Fireside (operator-led, candid)',
    'Masterclass (practical, hands-on)',
    'Demo Night (teams show what they shipped)',
    'Partner workshop (tools + use-cases + credits)'
];

const eventBring = [
    'A great speaker (or two)',
    'A practical topic founders actually need',
    'Optional: space, food, travel support, or tools/credits'
];

const eventGet = [
    'Brand trust with founders (earned, not forced)',
    'High-signal relationship building',
    'Optional: recruiting/talent visibility',
    'Content capture (photos, clips, recap) if you want it'
];

const sprintTypes = [
    {
        title: 'Challenge Sprint',
        description: '"Here\'s a real problem. Build the best approach."'
    },
    {
        title: 'Tooling Sprint',
        description: 'Enable teams with credits + templates + mentors'
    },
    {
        title: 'Industry Sprint',
        description: 'Target a local strength (fintech, legal/regtech, creative industries, health, manufacturing)'
    },
    {
        title: 'AI Agent Sprint',
        description: 'Practical agentic workflows, automation, integration'
    }
];

const sprintBring = [
    'A clear problem statement (or build theme)',
    'Mentors who can show up and help teams unblock',
    'Optional: credits/perks/prizes/pilot pathway'
];

const sprintGet = [
    'Early access to builders and teams',
    'Fresh ideas and prototypes against real problems',
    'Brand association with "shipping culture"',
    'Optional: pilot conversations with the best teams'
];

const sponsorWant = [
    'Consistent brand presence with founders (not one-off)',
    'A clear pipeline to talent and early teams',
    'A credible, public commitment to AI-native entrepreneurship',
    'Measurable activity: attendance, builds shipped, founder progression'
];

const sponsorFunds = [
    'A year-round events cadence (2–4/month)',
    'Sprint delivery (venues, ops, mentors, demo nights)',
    'Founder support and access (travel bursaries, credits, tools)',
    'Community infrastructure (newsletter, content, founder comms)'
];

const sponsorGets = [
    'Year-round, "always-on" presence across the ecosystem',
    'Priority involvement in Sprint themes and programming',
    'Named on the partner wall',
    'Quarterly founder access sessions (curated intros, demo nights, meetups)',
    'Full calendar access across events, sprints and programmes',
    'Visibility across channels (site, newsletter, event comms)',
    'A credible story: "We\'re building the future here."'
];

const greatPartner = [
    'You believe in our #givefirst mantra',
    'Want to help founders ship (not just "be associated")',
    'Can bring mentors/operators who are practical',
    'Are willing to show up consistently',
    'Care about AI-era company building (speed, modern tooling, real demos)'
];

const process = [
    {
        number: '01',
        title: 'Intro call',
        description: '30 mins — goals, audience, what you want to achieve'
    },
    {
        number: '02',
        title: 'Choose a tier',
        description: 'Event / Sprint / Founding Partner (or a mix)'
    },
    {
        number: '03',
        title: 'Design the activation',
        description: 'Topic/theme, roles, what founders get'
    },
    {
        number: '04',
        title: 'Deliver',
        description: 'We run tight ops; you bring the value'
    },
    {
        number: '05',
        title: 'Measure + iterate',
        description: 'Attendance, engagement, output, next steps'
    }
];

const faqs = [
    {
        question: 'Is this just Belfast?',
        answer: 'Belfast is the hub, but we\'re building a NI-wide network in practice.'
    },
    {
        question: 'Can we run something in Derry / elsewhere?',
        answer: 'Yes — if it\'s founder-first and we can deliver it properly.'
    },
    {
        question: 'Can we pitch at founders?',
        answer: 'No. You can teach, mentor, and support shipping. Founders can smell sales decks a mile away.'
    },
    {
        question: 'What\'s the quickest way to start?',
        answer: 'Co-host one event or sponsor one Sprint theme. Then scale what works.'
    }
];

// TODO: replace with your Calendly / Cal.com booking link, then this single
// constant updates every "Book an intro call" CTA on the page.
const bookCallHref = '#book-call';
---

<BaseLayout title="Partner with us" description="Techstars Belfast gives corporates, investors and universities a structured, founder-first way to back the next generation of Northern Irish founders.">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Partner with us</p>
            <h1>Back the next generation of <span class="accent">Northern Irish founders.</span></h1>
            <p class="lead hero-lead">
                Techstars Belfast gives corporates, investors and universities a structured, founder-first way to build relationships with the builders, researchers and operators shaping the next decade — before anyone else does.
            </p>
            <a href={bookCallHref} class="btn btn--accent">Book an intro call</a>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-64.jpg" alt="Speakers on stage at the Techstars Community Development Lab Belfast" class="hero-photo" />
        </div>
    </section>

    <!-- STAT STRIP -->
    <section class="stats">
        <div class="wrap stats-inner">
            {stats.map(stat => (
                <div class="stat-item">
                    <p>{stat}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- WHY PARTNER -->
    <section class="section">
        <div class="wrap">
            <p class="eyebrow">Why partner with us</p>
            <h2 class="why-head">Whichever seat you sit in.</h2>
            <div class="why-grid">
                {whyPartnerColumns.map(col => (
                    <div class="card why-card">
                        <p class="eyebrow">{col.audience}</p>
                        <p class="muted why-body">{col.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- WAYS TO PARTNER -->
    <section class="section divide">
        <div class="wrap">
            <p class="eyebrow">Ways to partner</p>
            <h2 class="ways-head">Three tiers.</h2>
            <p class="muted ways-intro">Pick the level of involvement that fits — start small, scale what works. Tap a tier to expand.</p>

            <!-- Tier 1: Event Partner -->
            <details class="partner-mode" id="event-partner">
                <summary class="mode-header">
                    <span class="mode-tier">Entry tier</span>
                    <div class="mode-header-text">
                        <h3>Event Partner</h3>
                        <p class="muted mode-tagline">Single-event sponsorship, mentor slots, brand on materials. The fastest way to start working with us.</p>
                    </div>
                    <span class="mode-toggle" aria-hidden="true"></span>
                </summary>

                <div class="mode-body">
                    <div class="mode-columns">
                        <div class="mode-column">
                            <h4>Good event formats</h4>
                            <ul>
                                {eventFormats.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="mode-column">
                            <h4>What you bring</h4>
                            <ul>
                                {eventBring.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="mode-column">
                            <h4>What you get</h4>
                            <ul>
                                {eventGet.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                    </div>

                    <p class="mode-rule"><strong>Founder-first rule:</strong> we keep the content practical. No sales pitches. If it's a product session, it must help founders ship.</p>
                </div>
            </details>

            <!-- Tier 2: Sprint Partner -->
            <details class="partner-mode" id="sprint-partner">
                <summary class="mode-header">
                    <span class="mode-tier">Mid tier</span>
                    <div class="mode-header-text">
                        <h3>Sprint Partner</h3>
                        <p class="muted mode-tagline">Sponsor a themed Sprint, set the challenge, meet teams, optional pilot pathway.</p>
                    </div>
                    <span class="mode-toggle" aria-hidden="true"></span>
                </summary>

                <div class="mode-body">
                    <h4>Sprint partner options</h4>
                    <div class="sprint-types-grid">
                        {sprintTypes.map(type => (
                            <div class="sprint-type-card">
                                <strong>{type.title}</strong>
                                <span class="muted">{type.description}</span>
                            </div>
                        ))}
                    </div>

                    <div class="mode-columns mode-columns--two">
                        <div class="mode-column">
                            <h4>What you bring</h4>
                            <ul>
                                {sprintBring.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="mode-column">
                            <h4>What you get</h4>
                            <ul>
                                {sprintGet.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                    </div>
                </div>
            </details>

            <!-- Tier 3: Founding Partner -->
            <details class="partner-mode partner-mode--top" id="founding-partner">
                <summary class="mode-header">
                    <span class="mode-tier mode-tier--top">Top tier</span>
                    <div class="mode-header-text">
                        <h3>Founding Partner</h3>
                        <p class="muted mode-tagline">Year-round presence, priority on Sprint themes, named on partner wall, quarterly founder access sessions, full calendar access.</p>
                    </div>
                    <span class="mode-toggle" aria-hidden="true"></span>
                </summary>

                <div class="mode-body">
                    <div class="mode-columns">
                        <div class="mode-column">
                            <h4>Ideal if you want</h4>
                            <ul>
                                {sponsorWant.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="mode-column">
                            <h4>What it funds</h4>
                            <ul>
                                {sponsorFunds.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="mode-column mode-column--highlight">
                            <h4>What Founding Partners get</h4>
                            <ul>
                                {sponsorGets.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                    </div>

                    <p class="mode-rule"><strong>Important:</strong> we do not sell founder access in a way that breaks trust. This stays founder-first.</p>
                </div>
            </details>
        </div>
    </section>

    <!-- GREAT PARTNER -->
    <section class="section--tight band divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Partner fit</p>
            <h2 class="great-head">What makes a great partner.</h2>
            <p class="great-intro">We build best with teams who show up, share, and play long-term. If this feels true, we should talk.</p>
            <ul class="great-list">
                {greatPartner.map(item => <li>{item}</li>)}
            </ul>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section">
        <div class="wrap">
            <p class="eyebrow">How it works</p>
            <h2 class="process-head">Five steps, no drama.</h2>
            <div class="process-grid">
                {process.map(step => (
                    <div class="process-step">
                        <span class="step-number">{step.number}</span>
                        <h3>{step.title}</h3>
                        <p class="muted">{step.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- BOOK CALL -->
    <section id="book-call" class="book-call">
        <div class="wrap wrap--mid book-inner">
            <h2>Ready to talk?</h2>
            <p class="lead">Tell us what you want to do and we'll propose the best format. 30 minutes, no slides.</p>
            <a href="https://www.linkedin.com/showcase/techstars-belfast" class="btn btn--accent" target="_blank" rel="noopener">Book an intro call</a>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section">
        <div class="wrap wrap--mid">
            <p class="eyebrow">FAQ</p>
            <div class="faq-list">
                {faqs.map(faq => (
                    <div class="faq-item">
                        <h3>{faq.question}</h3>
                        <p class="muted">{faq.answer}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 4rem; }
    .hero h1 { margin: 1.25rem 0 1.75rem; font-size: clamp(2.2rem, 5vw, 3.6rem); }
    .hero-lead { margin-bottom: 2.5rem; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3.5rem; }

    /* STATS */
    .stats { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-subtle); }
    .stats-inner { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; padding: 2.5rem 1.5rem; }
    .stat-item p { font-family: var(--mono); font-size: 0.95rem; color: var(--ink-soft); line-height: 1.5; }

    /* WHY */
    .why-head { margin: 0.75rem 0 2.5rem; }
    .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .why-body { margin-top: 0.9rem; font-size: 0.98rem; }

    /* WAYS / TIERS */
    .ways-head { margin: 0.75rem 0 0.75rem; }
    .ways-intro { margin-bottom: 2.5rem; max-width: 600px; }

    .partner-mode {
        border: 1px solid var(--line);
        border-radius: 16px;
        margin-bottom: 1rem;
        background: var(--bg);
        overflow: hidden;
        transition: border-color var(--t);
    }
    .partner-mode:hover { border-color: #d2d1c9; }
    .partner-mode--top { border-color: var(--accent); }

    .mode-header {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1.75rem 2rem;
        cursor: pointer;
        list-style: none;
    }
    .mode-header::-webkit-details-marker { display: none; }
    .mode-tier {
        font-family: var(--mono);
        font-size: 0.66rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 4px 12px;
        border-radius: 999px;
        background: var(--bg-sunken);
        color: var(--ink-soft);
        white-space: nowrap;
        flex-shrink: 0;
    }
    .mode-tier--top { background: var(--accent-soft); color: var(--accent); }
    .mode-header-text { flex: 1; }
    .mode-header-text h3 { font-size: 1.3rem; margin-bottom: 0.25rem; }
    .mode-tagline { font-size: 0.95rem; line-height: 1.5; }
    .mode-toggle {
        flex-shrink: 0;
        width: 28px; height: 28px;
        border: 1px solid var(--line);
        border-radius: 999px;
        position: relative;
    }
    .mode-toggle::before, .mode-toggle::after {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        width: 10px; height: 1.5px;
        background: var(--ink-soft);
        transform: translate(-50%, -50%);
        transition: transform var(--t);
    }
    .mode-toggle::after { transform: translate(-50%, -50%) rotate(90deg); }
    details[open] .mode-toggle::after { transform: translate(-50%, -50%) rotate(0deg); }

    .mode-body { padding: 0 2rem 2rem; border-top: 1px solid var(--line); }
    .mode-body > :first-child { margin-top: 1.75rem; }
    .mode-body h4 {
        font-family: var(--mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
        margin-bottom: 0.9rem;
    }
    .mode-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; margin-top: 1.75rem; }
    .mode-columns--two { grid-template-columns: repeat(2, 1fr); }
    .mode-column ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
    .mode-column li {
        font-size: 0.93rem;
        color: var(--ink-soft);
        padding-left: 1.4rem;
        position: relative;
        line-height: 1.5;
    }
    .mode-column li::before { content: "→"; position: absolute; left: 0; color: var(--accent); font-weight: 700; }
    .mode-column--highlight { background: var(--accent-soft); border-radius: 12px; padding: 1.25rem; }

    .sprint-types-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 0.5rem; }
    .sprint-type-card {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1.1rem 1.25rem;
        border: 1px solid var(--line);
        border-radius: 12px;
        font-size: 0.93rem;
    }
    .sprint-type-card strong { font-size: 0.98rem; }

    .mode-rule {
        margin-top: 1.75rem;
        padding: 1rem 1.25rem;
        background: var(--bg-subtle);
        border-radius: 12px;
        font-size: 0.9rem;
        color: var(--ink-soft);
    }

    /* GREAT PARTNER */
    .band { background: var(--accent-soft); }
    .great-head { margin: 0.75rem 0 1rem; }
    .great-intro { color: #0a3d24; margin-bottom: 2rem; font-size: 1.05rem; }
    .great-list { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
    .great-list li {
        font-size: 1.02rem;
        color: #0a3d24;
        padding-left: 1.6rem;
        position: relative;
    }
    .great-list li::before { content: "✓"; position: absolute; left: 0; color: var(--accent); font-weight: 700; }

    /* PROCESS */
    .process-head { margin: 0.75rem 0 2.5rem; }
    .process-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.5rem; }
    .step-number { font-family: var(--mono); font-size: 0.8rem; font-weight: 700; color: var(--accent); }
    .process-step h3 { font-size: 1.05rem; margin: 0.5rem 0 0.4rem; }
    .process-step p { font-size: 0.88rem; line-height: 1.5; }

    /* BOOK CALL */
    .book-call { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .book-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .book-call h2 { color: var(--bg); }
    .book-call .lead { color: rgba(255,255,255,0.72); max-width: 44ch; }

    /* FAQ */
    .faq-list { display: flex; flex-direction: column; margin-top: 1.5rem; }
    .faq-item { padding: 1.5rem 0; border-top: 1px solid var(--line); }
    .faq-item:last-child { border-bottom: 1px solid var(--line); }
    .faq-item h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }
    .faq-item p { font-size: 0.98rem; }

    @media (max-width: 900px) {
        .hero-photo { aspect-ratio: 16 / 10; }
        .stats-inner { grid-template-columns: 1fr; gap: 1rem; }
        .why-grid { grid-template-columns: 1fr; }
        .mode-columns, .mode-columns--two { grid-template-columns: 1fr; }
        .sprint-types-grid { grid-template-columns: 1fr; }
        .process-grid { grid-template-columns: repeat(2, 1fr); }
        .mode-header { flex-wrap: wrap; gap: 0.75rem 1rem; }
    }
</style>
