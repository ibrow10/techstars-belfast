---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
    '10,000+ founders in the global Techstars network',
    '$130.6B+ market cap of Techstars companies',
    '150+ countries represented'
];

const whyPartnerColumns = [
    {
        audience: 'For corporates',
        description: 'Early talent pipeline. Pre-IPO startup access. Credible AI-native positioning your customers and recruits will notice.'
    },
    {
        audience: 'For investors',
        description: 'Deal flow at the earliest possible stage. Curated intros. Co-invest signals from a global Techstars network.'
    },
    {
        audience: 'For universities & public sector',
        description: 'Translate research into commercial outcomes. Deliver entrepreneurship outputs that funders can measure.'
    }
];

const eventFormats = [
    'Founder Night (short talks + networking)',
    'AMA / Fireside (operator-led, candid)',
    'Masterclass (practical, hands-on)',
    'Demo Night (teams show what they shipped)',
    'Partner workshop (tools + use-cases + credits)'
];

const eventBring = [
    'A great speaker (or two)',
    'A practical topic founders actually need',
    'Optional: space, food, travel support, or tools/credits'
];

const eventGet = [
    'Brand trust with founders (earned, not forced)',
    'High-signal relationship building',
    'Optional: recruiting/talent visibility',
    'Content capture (photos, clips, recap) if you want it'
];

const sprintTypes = [
    {
        title: 'Challenge Sprint',
        description: '"Here\'s a real problem. Build the best approach."'
    },
    {
        title: 'Tooling Sprint',
        description: 'Enable teams with credits + templates + mentors'
    },
    {
        title: 'Industry Sprint',
        description: 'Target a local strength (fintech, legal/regtech, creative industries, health, manufacturing)'
    },
    {
        title: 'AI Agent Sprint',
        description: 'Practical agentic workflows, automation, integration'
    }
];

const sprintBring = [
    'A clear problem statement (or build theme)',
    'Mentors who can show up and help teams unblock',
    'Optional: credits/perks/prizes/pilot pathway'
];

const sprintGet = [
    'Early access to builders and teams',
    'Fresh ideas and prototypes against real problems',
    'Brand association with "shipping culture"',
    'Optional: pilot conversations with the best teams'
];

const sponsorWant = [
    'Consistent brand presence with founders (not one-off)',
    'A clear pipeline to talent and early teams',
    'A credible, public commitment to AI-native entrepreneurship',
    'Measurable activity: attendance, builds shipped, founder progression'
];

const sponsorFunds = [
    'A year-round events cadence (2–4/month)',
    'Sprint delivery (venues, ops, mentors, demo nights)',
    'Founder support and access (travel bursaries, credits, tools)',
    'Community infrastructure (newsletter, content, founder comms)'
];

const sponsorGets = [
    'Year-round, "always-on" presence across the ecosystem',
    'Priority involvement in Sprint themes and programming',
    'Named on the partner wall',
    'Quarterly founder access sessions (curated intros, demo nights, meetups)',
    'Full calendar access across events, sprints and programmes',
    'Visibility across channels (site, newsletter, event comms)',
    'A credible story: "We\'re building the future here."'
];

const greatPartner = [
    'You believe in our #givefirst mantra',
    'Want to help founders ship (not just "be associated")',
    'Can bring mentors/operators who are practical',
    'Are willing to show up consistently',
    'Care about AI-era company building (speed, modern tooling, real demos)'
];

const process = [
    {
        number: '01',
        title: 'Intro call',
        description: '30 mins: goals, audience, what you want to achieve'
    },
    {
        number: '02',
        title: 'Choose a tier',
        description: 'Event / Sprint / Founding Partner (or a mix)'
    },
    {
        number: '03',
        title: 'Design the activation',
        description: 'Topic/theme, roles, what founders get'
    },
    {
        number: '04',
        title: 'Deliver',
        description: 'We run tight ops; you bring the value'
    },
    {
        number: '05',
        title: 'Measure + iterate',
        description: 'Attendance, engagement, output, next steps'
    }
];

const faqs = [
    {
        question: 'Is this just Belfast?',
        answer: 'Belfast is the hub, but we\'re building a NI-wide network in practice.'
    },
    {
        question: 'Can we run something in Derry / elsewhere?',
        answer: 'Yes, if it\'s founder-first and we can deliver it properly.'
    },
    {
        question: 'Can we pitch at founders?',
        answer: 'No. You can teach, mentor, and support shipping. Founders can smell sales decks a mile away.'
    },
    {
        question: 'What\'s the quickest way to start?',
        answer: 'Co-host one event or sponsor one Sprint theme. Then scale what works.'
    }
];

// TODO: replace with a Calendly / Cal.com booking link once Ian supplies one,
// then this single constant updates every "Book an intro call" CTA on the page.
const bookCallHref = 'mailto:ian@ormeaulabs.com?subject=Techstars%20Belfast%20intro%20call';
---

<BaseLayout title="Partner with us">
    <!-- Hero Section -->
    <section class="partner-hero">
        <div class="container">
            <span class="hero-label">PARTNER WITH US</span>
            <h1>Back the next generation of Northern Irish founders.</h1>
            <p class="hero-subhead">
                Techstars Belfast gives corporates, investors and universities a structured, founder-first way to build relationships with the builders, researchers and operators shaping the next decade, before anyone else does.
            </p>

            <a href={bookCallHref} class="btn btn--accent hero-cta">Book an intro call</a>
        </div>
    </section>

    <!-- Stat Strip -->
    <section class="stat-strip">
        <div class="container">
            <div class="stat-grid">
                {stats.map(stat => (
                    <div class="stat-item">
                        <p>{stat}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Why Partner With Us -->
    <section class="why-partner-section">
        <div class="container">
            <h2>WHY PARTNER WITH US</h2>
            <div class="why-grid">
                {whyPartnerColumns.map(col => (
                    <div class="why-column">
                        <h3>{col.audience}</h3>
                        <p>{col.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Ways to Partner -->
    <section class="ways-section">
        <div class="container">
            <h2>WAYS TO PARTNER</h2>
            <p class="ways-intro">Three tiers. Pick the level of involvement that fits. Start small, scale what works. Tap a tier to expand.</p>

            <!-- Tier 1: Event Partner -->
            <details class="partner-mode" id="event-partner">
                <summary class="mode-header">
                    <span class="mode-tier mode-tier--entry">Entry tier</span>
                    <div class="mode-header-text">
                        <h3>Event Partner</h3>
                        <p class="mode-tagline">Single-event sponsorship, mentor slots, brand on materials. The fastest way to start working with us.</p>
                    </div>
                    <span class="mode-toggle" aria-hidden="true"></span>
                </summary>

                <div class="mode-body">
                    <div class="mode-content">
                        <div class="mode-column">
                            <h4>Good event formats</h4>
                            <ul>
                                {eventFormats.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="mode-column">
                            <h4>What you bring</h4>
                            <ul>
                                {eventBring.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="mode-column">
                            <h4>What you get</h4>
                            <ul>
                                {eventGet.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                    </div>

                    <p class="mode-rule"><i data-lucide="alert-circle"></i> <strong>Founder-first rule:</strong> we keep the content practical. No sales pitches. If it's a product session, it must help founders ship.</p>
                </div>
            </details>

            <!-- Tier 2: Sprint Partner -->
            <details class="partner-mode" id="sprint-partner">
                <summary class="mode-header">
                    <span class="mode-tier mode-tier--mid">Mid tier</span>
                    <div class="mode-header-text">
                        <h3>Sprint Partner</h3>
                        <p class="mode-tagline">Sponsor a themed Sprint, set the challenge, meet teams, optional pilot pathway.</p>
                    </div>
                    <span class="mode-toggle" aria-hidden="true"></span>
                </summary>

                <div class="mode-body">
                    <div class="mode-content">
                        <div class="sprint-types">
                            <h4>Sprint partner options</h4>
                            <div class="sprint-types-grid">
                                {sprintTypes.map(type => (
                                    <div class="sprint-type-card">
                                        <strong>{type.title}</strong>
                                        <span>{type.description}</span>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="mode-columns">
                            <div class="mode-column sprint-column">
                                <div class="sprint-column-header">
                                    <h4>What you bring</h4>
                                    <span class="sprint-column-tag">Input</span>
                                </div>
                                <ul class="sprint-list">
                                    {sprintBring.map(item => <li>{item}</li>)}
                                </ul>
                            </div>
                            <div class="mode-column sprint-column">
                                <div class="sprint-column-header">
                                    <h4>What you get</h4>
                                    <span class="sprint-column-tag">Output</span>
                                </div>
                                <ul class="sprint-list">
                                    {sprintGet.map(item => <li>{item}</li>)}
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </details>

            <!-- Tier 3: Founding Partner -->
            <details class="partner-mode partner-mode--top" id="founding-partner">
                <summary class="mode-header">
                    <span class="mode-tier mode-tier--top">Top tier</span>
                    <div class="mode-header-text">
                        <h3>Founding Partner</h3>
                        <p class="mode-tagline">Year-round presence, priority on Sprint themes, named on partner wall, quarterly founder access sessions, full calendar access.</p>
                    </div>
                    <span class="mode-toggle" aria-hidden="true"></span>
                </summary>

                <div class="mode-body">
                    <div class="mode-content sponsor-content">
                        <div class="sponsor-column">
                            <h4>Founding Partner is ideal if you want</h4>
                            <ul>
                                {sponsorWant.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="sponsor-column">
                            <h4>What it funds</h4>
                            <ul>
                                {sponsorFunds.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                        <div class="sponsor-column highlight-column">
                            <h4>What Founding Partners get</h4>
                            <ul>
                                {sponsorGets.map(item => <li>{item}</li>)}
                            </ul>
                        </div>
                    </div>

                    <p class="mode-rule"><i data-lucide="shield"></i> <strong>Important:</strong> we do not sell founder access in a way that breaks trust. This stays founder-first.</p>
                </div>
            </details>
        </div>
    </section>

    <!-- Great Partner -->
    <section class="great-partner-section">
        <div class="container">
            <div class="great-partner-block">
                <span class="great-eyebrow">PARTNER FIT</span>
                <h2>WHAT MAKES A GREAT PARTNER</h2>
                <p class="great-intro">We build best with teams who show up, share, and play long-term. If this feels true, we should talk.</p>
                <div class="great-partner-grid">
                    {greatPartner.map(item => (
                        <div class="great-card">
                            <i data-lucide="check-circle-2"></i>
                            <span>{item}</span>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="process-section">
        <div class="container">
            <h2>HOW IT WORKS</h2>
            <div class="process-grid">
                {process.map(step => (
                    <div class="process-step">
                        <span class="step-number">{step.number}</span>
                        <h3>{step.title}</h3>
                        <p>{step.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Book an intro call -->
    <section id="book-call" class="book-call-section">
        <div class="container">
            <div class="book-call-block">
                <h2>READY TO TALK?</h2>
                <p class="book-call-intro">Tell us what you want to do and we'll propose the best format. 30 minutes, no slides.</p>
                <a href={bookCallHref} class="btn btn--accent">Book an intro call</a>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
        <div class="container">
            <h2>FAQ</h2>
            <div class="faq-grid">
                {faqs.map(faq => (
                    <div class="faq-item">
                        <h3>{faq.question}</h3>
                        <p>{faq.answer}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* HERO SECTION */
    .partner-hero {
        padding-top: 160px;
        padding-bottom: 5rem;
        border-bottom: 1px solid var(--border-color);
        background: linear-gradient(135deg, rgba(0, 230, 118, 0.05) 0%, transparent 50%);
    }

    .partner-hero .container {
        max-width: 900px;
    }

    .hidden {
        display: none;
    }

    .hero-label {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-color);
        margin-bottom: 1rem;
    }

    .partner-hero h1 {
        font-size: clamp(2.25rem, 5.5vw, 3.5rem);
        line-height: 1.1;
        margin-bottom: 1.5rem;
        text-transform: none;
        letter-spacing: -0.02em;
    }

    .hero-subhead {
        font-size: 1.2rem;
        color: #ccc;
        line-height: 1.6;
        margin-bottom: 2.5rem;
        max-width: 760px;
    }

    .hero-cta {
        font-size: 1rem;
        padding: 14px 28px;
    }

    /* STAT STRIP */
    .stat-strip {
        padding: 2.5rem 0;
        border-bottom: 1px solid var(--border-color);
        background: #0a0a0a;
    }

    .stat-strip .container {
        max-width: 1100px;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }

    .stat-item {
        padding: 1rem 1.25rem;
        text-align: center;
    }

    .stat-item p {
        font-family: var(--font-mono);
        font-size: 0.95rem;
        color: #ddd;
        margin: 0;
        line-height: 1.4;
        max-width: none;
    }

    /* WHY PARTNER */
    .why-partner-section {
        padding: 5rem 0;
        border-bottom: 1px solid var(--border-color);
    }

    .why-partner-section .container {
        max-width: 1100px;
    }

    .why-partner-section h2 {
        margin-bottom: 2.5rem;
    }

    .why-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .why-column {
        padding: 2rem;
        background: #161616;
        border: 1px solid var(--border-color);
        border-radius: 12px;
    }

    .why-column h3 {
        font-size: 0.95rem;
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--accent-color);
        margin-bottom: 1rem;
    }

    .why-column p {
        font-size: 1rem;
        color: #ccc;
        line-height: 1.6;
        margin: 0;
    }

    /* WAYS TO PARTNER */
    .ways-section {
        padding: 5rem 0;
        border-bottom: 1px solid var(--border-color);
        background: #0a0a0a;
    }

    .ways-section .container {
        max-width: 1000px;
    }

    .ways-section > .container > h2 {
        margin-bottom: 0.75rem;
    }

    .ways-intro {
        font-size: 1.05rem;
        color: var(--text-muted);
        margin-bottom: 3rem;
    }

    .partner-mode {
        background: #161616;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
        transition: border-color 0.2s ease;
    }

    .partner-mode[open] {
        border-color: rgba(255, 255, 255, 0.18);
    }

    .partner-mode--top {
        border-color: rgba(0, 230, 118, 0.4);
        background: linear-gradient(180deg, rgba(0, 230, 118, 0.04) 0%, #161616 100%);
    }

    .partner-mode--top[open] {
        border-color: rgba(0, 230, 118, 0.55);
    }

    .mode-header {
        display: flex;
        gap: 1.5rem;
        align-items: center;
        cursor: pointer;
        list-style: none;
        user-select: none;
    }

    .mode-header::-webkit-details-marker {
        display: none;
    }

    .mode-header:hover .mode-toggle::before,
    .mode-header:hover .mode-toggle::after {
        background: var(--accent-color);
    }

    .mode-header-text {
        flex: 1;
        min-width: 0;
    }

    .mode-toggle {
        position: relative;
        width: 28px;
        height: 28px;
        flex-shrink: 0;
        display: inline-block;
    }

    .mode-toggle::before,
    .mode-toggle::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        background: #888;
        transition: transform 0.2s ease, background 0.2s ease;
    }

    .mode-toggle::before {
        width: 14px;
        height: 2px;
        transform: translate(-50%, -50%);
    }

    .mode-toggle::after {
        width: 2px;
        height: 14px;
        transform: translate(-50%, -50%);
    }

    .partner-mode[open] .mode-toggle::after {
        transform: translate(-50%, -50%) scaleY(0);
    }

    .mode-body {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-color);
    }

    .mode-tier {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        padding: 0.45rem 0.85rem;
        border-radius: 999px;
        flex-shrink: 0;
        white-space: nowrap;
        align-self: center;
    }

    .mode-tier--entry {
        color: #ddd;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .mode-tier--mid {
        color: #a29bfe;
        background: rgba(108, 92, 231, 0.15);
        border: 1px solid rgba(108, 92, 231, 0.35);
    }

    .mode-tier--top {
        color: var(--accent-color);
        background: rgba(0, 230, 118, 0.12);
        border: 1px solid rgba(0, 230, 118, 0.4);
    }

    .mode-header h3 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        text-transform: none;
        font-family: var(--font-main);
    }

    .mode-tagline {
        font-size: 1rem;
        color: var(--text-muted);
    }

    .mode-content {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2rem;
        margin-bottom: 1.5rem;
    }

    .mode-column h4 {
        font-size: 0.85rem;
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #999;
        margin-bottom: 1rem;
    }

    .mode-column ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .mode-column li {
        font-size: 0.95rem;
        color: #aaa;
        padding-left: 1.25rem;
        margin-bottom: 0.75rem;
        position: relative;
    }

    .mode-column li::before {
        content: "•";
        position: absolute;
        left: 0;
        color: var(--accent-color);
    }

    .mode-rule {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        font-size: 0.9rem;
        color: var(--text-muted);
        padding: 1rem;
        background: rgba(0, 0, 0, 0.3);
        border-radius: 8px;
        margin-top: 1rem;
    }

    .mode-rule i {
        width: 18px;
        height: 18px;
        color: var(--accent-color);
        flex-shrink: 0;
        margin-top: 2px;
    }

    .mode-rule strong {
        color: #ccc;
    }

    /* Sprint specific */
    #sprint-partner .mode-content {
        display: block;
    }

    .sprint-types {
        grid-column: 1 / -1;
        margin-bottom: 1.5rem;
    }

    .sprint-types h4 {
        font-size: 0.85rem;
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #999;
        margin-bottom: 1rem;
    }

    .sprint-types-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    .sprint-type-card {
        padding: 1rem;
        background: #0f0f0f;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .sprint-type-card strong {
        font-size: 0.95rem;
        color: #fff;
    }

    .sprint-type-card span {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .mode-columns {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 2rem;
    }

    .sprint-column {
        background: #0f0f0f;
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

    .sprint-column::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at top left, rgba(255, 255, 255, 0.06), transparent 55%);
        pointer-events: none;
    }

    .sprint-column-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
        position: relative;
        z-index: 1;
    }

    .sprint-column-tag {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-family: var(--font-mono);
        color: var(--accent-color);
        border: 1px solid rgba(0, 230, 118, 0.35);
        border-radius: 999px;
        padding: 0.35rem 0.75rem;
        background: rgba(0, 230, 118, 0.08);
    }

    .sprint-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.9rem;
        position: relative;
        z-index: 1;
    }

    .sprint-list li {
        color: #d4d4d4;
        font-size: 0.95rem;
        line-height: 1.5;
        padding-left: 1.5rem;
        position: relative;
    }

    .sprint-list li::before {
        content: '•';
        position: absolute;
        left: 0;
        top: 0;
        color: var(--accent-color);
        font-size: 1.2rem;
        line-height: 1.5;
    }

    /* Sponsor specific */
    .sponsor-content {
        grid-template-columns: repeat(3, 1fr);
    }

    .sponsor-column h4 {
        font-size: 0.85rem;
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #999;
        margin-bottom: 1rem;
    }

    .sponsor-column ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .sponsor-column li {
        font-size: 0.9rem;
        color: #aaa;
        padding-left: 1.25rem;
        margin-bottom: 0.75rem;
