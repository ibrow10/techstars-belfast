---
import BaseLayout from '../layouts/BaseLayout.astro';

const monthToNum = { JAN: 1, FEB: 2, MAR: 3, APR: 4, MAY: 5, JUN: 6, JUL: 7, AUG: 8, SEP: 9, OCT: 10, NOV: 11, DEC: 12 };

const events = [
    { day: '03', month: 'FEB', year: 2026, finished: true, tag: 'PARTNER SESSION', tagType: 'partner', title: 'Founder Labs x The AMP: AMA', time: '11:00 AM – 3:00 PM', location: 'Ebrington Square, Derry', audience: 'Cohort 4 focus', description: 'Join the Founder Labs team at The AMP for an open conversation about Cohort 4. Includes a Fireside Chat with Orla Lynch and Ian Browne, plus insights from alumni.', link: 'https://luma.com/ixnvtb9s', active: true, status: 'closed' },
    { day: '05', month: 'FEB', year: 2026, finished: true, tag: 'Virtual Pre-Accelerator', tagType: 'remote', title: 'Founder AMA: Techstars Founder Catalyst', time: '3:00 PM – 4:00 PM GMT', location: 'Google Meet', audience: 'Founders only', description: 'Ask questions live, no filters, no sales pitch. Join the Techstars team to find out if the 10-week virtual pre-accelerator is the right fit for your startup. Applications have closed for Spring 2026.', link: 'https://luma.com/a9e83czs', active: true, status: 'closed' },
    { day: '05', month: 'FEB', year: 2026, finished: true, tag: 'PARTNER SESSION', tagType: 'partner', title: 'Founders Night X Founder Labs', time: '5:30 PM – 7:30 PM', location: 'Ormeau Labs, Belfast', audience: 'Cohort 4 Launch', description: 'Dive into startups and scaling with Orla Lynch. Get an exclusive first look at Cohort 4 and hear real-world insights from previous cohort members in an interactive setting.', link: 'https://luma.com/6sqbnad2', active: true, status: 'closed' },
    { day: '12', month: 'FEB', year: 2026, finished: true, tag: 'Community Event', tagType: 'in-person', title: 'Coinbase x Ormeau Labs: Future of Commerce', time: '5:30 PM – 7:30 PM', location: 'Ormeau Labs, Belfast', audience: 'NI-Blockchain Partnership', description: 'Unpick the future of commerce, agents, and stablecoins with Evan (Coinbase) and Ian (Ormeau Labs). Part of the new QUB partnership launching Techstars in NI.', link: '#', active: true },
    { day: '04', month: 'MAR', year: 2026, finished: true, tag: 'Build Challenge', tagType: 'in-person', title: 'Founders vs VCs: Agent Wars', time: '11:00 AM – 2:30 PM', location: 'Ormeau Labs', audience: 'Technical Build', description: 'Who can build the best AI agents in just 2 hours? A high-stakes live build challenge between local founders and the investment community.', link: '#', active: false },
    { day: '05', month: 'MAR', year: 2026, finished: true, tag: 'Founders Night Series', tagType: 'in-person', title: 'Founder ❤️ Investor: Elkstone', time: '5:30 PM – 7:30 PM', location: 'Ormeau Labs', audience: 'Elkstone Fund', description: 'Elkstone have announced the first close on their new fund and are keen to invest in high potential early stage companies in Northern Ireland. Come hear from the team and one of their portfolio companies.', link: '#', active: false },
    { day: '16', month: 'MAR', year: 2026, finished: true, tag: 'Virtual Pre-Accelerator', tagType: 'remote', title: 'Founder Catalyst Kick Off', time: '4:00 PM – 6:00 PM', location: 'Google Meet', audience: 'Cohort Participants', description: 'The official kick off for the Founder Catalyst cohort. Get ready to start your 10-week journey with Techstars.', link: '#', active: false, private: true },
    { day: '29', month: 'APR', year: 2026, finished: true, tag: 'Community Event', tagType: 'in-person', title: 'AI Build Day', time: '12:00 PM – 4:30 PM', location: 'The AMP Growth Incubator, Derry', audience: 'Founders, builders & operators', description: 'Techstars Belfast x The AMP x Invest NI. A day-long AI build event: morning intro to AI models and tools for founders and operators, followed by a two-hour afternoon build sprint on workflows, websites, agents or products, ending in a show-and-tell. Bring a laptop and ideas. Come to learn. Stay to build. Leave with something that works.', link: 'https://luma.com/72mco2r0', active: true },
    { day: '09', month: 'APR', year: 2026, finished: true, tag: 'Networking', tagType: 'in-person', title: 'Stripe Snacks: Agentic Commerce', time: '11:00 AM – 1:00 PM', location: 'Ormeau Labs', audience: 'Stripe Partnership', description: 'Continuing the agentic commerce discussion with content and networking in partnership with our friends at Stripe. Coffee, snacks, and shipping agents.', link: '#', active: false },
    { day: '25', month: 'APR', year: 2026, finished: true, tag: 'PARTNER SESSION', tagType: 'partner', title: 'HackBelfast 2026', time: '25-26 April, 10:00 AM start', location: "Queen's University Belfast, Computer Science Building", audience: '175+ students across Ireland', description: "Northern Ireland's largest student-led hackathon. A 24-hour innovation sprint tackling real-world challenges across Builder, Non-Builder, and Finance tracks. Techstars Belfast is a community partner.", link: 'https://www.hackbelfast.org/register', active: true },
    { day: '06', month: 'MAY', year: 2026, finished: true, tag: 'PARTNER SESSION', tagType: 'partner', title: 'Techstars Community Development Lab', time: '12:30 PM – 5:00 PM', location: 'Ormeau Labs, Belfast', audience: 'Invite only', description: 'Techstars CDL is an invite-only session bringing together founders, investors, universities, corporates, government and all other stakeholders to understand how best to support the startup ecosystem for the future. Places are limited — if you want to attend please ping us on LinkedIn.', link: 'https://www.linkedin.com/showcase/techstars-belfast', active: true, private: true },
    { day: '07', month: 'MAY', year: 2026, finished: true, tag: 'Virtual Fireside', tagType: 'remote', title: 'Virtual Fireside: James Garvey (Self Financial)', time: '4:00 PM – 5:30 PM BST', location: 'Online via Luma', audience: 'Founders & operators', description: 'Exclusive virtual fireside with James Garvey — founder and former CEO of Self Financial, the Techstars portfolio company he scaled to a billion-dollar valuation serving millions of US customers. Topics: rapid growth without losing customer focus, raising $120M+ in venture capital, strategic bank partnerships, and scaling a 600-person team. Fintech-flavoured but the playbook generalises.', link: 'https://luma.com/x7cek4nn', active: true },
    { day: '07', month: 'MAY', year: 2026, finished: true, tag: 'Founders Night Series', tagType: 'in-person', title: 'Founders Night: Aidan Larkin (Asset Reality)', time: '5:30 PM – 7:30 PM', location: 'Ormeau Labs, Belfast', audience: 'Founders & operators', description: 'Our monthly Founders Night brings the local startup community together to interview founders and dig into their journeys. This month: Aidan Larkin, co-founder and CEO of Asset Reality — a former UK criminal investigator now building digital asset custody and compliance for recovered assets. Drinks and food provided.', link: 'https://luma.com/alagvajn', active: true },
    { day: '03', month: 'JUN', year: 2026, finished: true, tag: 'Founder Catalyst Showcase', tagType: 'in-person', title: 'Founder Catalyst: End of Programme Showcase', time: '2:00 PM – 5:00 PM', location: "Queen's Business School, Seminar Room 2", audience: 'Mentors, investors & ecosystem', description: "The final showcase for the Techstars Founder Catalyst Global Spring 2026 cohort. Fast-paced one-minute pitches from founders across Sarajevo, Omaha, Istanbul, Uzbekistan, Belfast and the NatWest Startup Network. Belfast teams present in-person; others join virtually. Open to mentors, investors, and anyone backing early-stage founders. Refreshments provided.", link: 'https://luma.com/7rs4jk5j', active: true },
    { day: '04', month: 'JUN', year: 2026, finished: true, tag: 'Founders Night Series', tagType: 'in-person', title: 'Founders Night: Jonny Clarke (Locate a Locum)', time: '5:30 PM – 7:30 PM', location: 'Ormeau Labs, Belfast', audience: 'Founders & operators', description: 'June edition of our monthly Founders Night. This month: Jonny Clarke, founder of Locate a Locum — a workforce management platform for healthcare workers and organisations. Built around the belief that every healthcare worker deserves the tools to manage their own work life. Drinks and food provided.', link: 'https://luma.com/u2x1q34k', active: true },
    { day: '09', month: 'JUN', year: 2026, finished: false, tag: 'PARTNER SESSION', tagType: 'partner', title: 'From Start-up to Success with Copeland Distillery', time: '5:00 PM – 7:00 PM', location: 'Ormeau Labs, Belfast', audience: 'Open to all', description: "Copeland Distillery founder Gareth Irvine sits down with Ormeau Labs and A&L Goodbody for an informal evening on building one of Northern Ireland's most popular craft distilleries — from start-up to success. A proper founder story from someone who's done it the hard way. Pizzas, drinks, and good conversation.", link: 'https://luma.com/nm5xzmlx', active: true },
    { day: '23', month: 'JUN', year: 2026, finished: false, tag: 'PARTNER SESSION', tagType: 'partner', title: 'Claude Code Meetup for Everyone', time: '6:00 PM – 8:00 PM', location: 'Ormeau Labs, Belfast', audience: 'All skill levels', description: 'An evening of Claude Code with the community: four talks from practitioners on real-world builds, a hands-on workshop, and time to network. No experience required, from seasoned Claude developers to curious newcomers.', link: 'https://luma.com/eqom6q5t?tk=qtPD6B', active: true },
    { day: '25', month: 'JUN', year: 2026, finished: false, tag: 'PARTNER SESSION', tagType: 'partner', title: 'Founder Labs Demo Day', time: '2:45 PM doors', location: 'Ormeau Labs, Belfast', audience: 'Investors & founders', description: 'Ten companies from Founder Labs Cohort 4 take the stage. After three months heads-down, building, finding first customers and mapping the path to investment, the founders pitch their businesses, followed by networking and drinks.', link: 'https://luma.com/syl0pl0j', active: true }
];

const sortKey = (e) => e.year * 10000 + monthToNum[e.month] * 100 + parseInt(e.day);
const upcomingEvents = events.filter(e => !e.finished).sort((a, b) => sortKey(a) - sortKey(b));
const finishedEvents = events.filter(e => e.finished).sort((a, b) => sortKey(b) - sortKey(a));

// invert: white logo assets that need inverting to show on a light background
const partnerLogos = [
    { src: '/images/openai.png', alt: 'OpenAI' },
    { src: '/images/google.png', alt: 'Google' },
    { src: '/images/stripe.png', alt: 'Stripe' },
    { src: '/images/aws.png', alt: 'AWS' },
    { src: '/images/logo-base.png', alt: 'Base', invert: true },
    { src: '/images/generalcatalyst.png', alt: 'General Catalyst' },
    { src: '/images/frontline.png', alt: 'Frontline' },
    { src: '/images/earlybird.png', alt: 'Earlybird' },
    { src: '/images/logo-surevalleyventures.webp', alt: 'Sure Valley Ventures', invert: true },
    { src: '/images/dogpatch.png', alt: 'Dogpatch', invert: true },
    { src: '/images/the-amp.png', alt: 'The AMP', invert: true },
];
---

<BaseLayout title="Events" description="Founder nights, firesides, build days and showcases across Northern Ireland. Good rooms, useful sessions, real talk.">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Events</p>
            <h1>Good rooms.<br /><span class="accent">Real talk.</span></h1>
            <p class="lead hero-lead">
                Founders don't need more panels. They need people who'll tell the truth.
            </p>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-78.jpg" alt="Founders networking at a Techstars Belfast event" class="hero-photo" />
        </div>
    </section>

    <!-- PARTNER STRIP -->
    <section class="partner-strip">
        <div class="wrap">
            <p class="eyebrow strip-label">Who we've run events with</p>
            <div class="partner-logos-wrapper">
                <div class="partner-logos">
                    {partnerLogos.map(l => <img src={l.src} alt={l.alt} class={`partner-logo${l.invert ? ' invert' : ''}`} />)}
                    {partnerLogos.map(l => <img src={l.src} alt="" aria-hidden="true" class={`partner-logo${l.invert ? ' invert' : ''}`} />)}
                </div>
            </div>
        </div>
    </section>

    <!-- UPCOMING -->
    <section id="upcoming" class="section--tight">
        <div class="wrap">
            <h2 class="events-head">Upcoming</h2>
            <p class="muted events-note">Everything upcoming is below. If it's full, join the list anyway — we run these often.</p>

            <div class="events-grid">
                {upcomingEvents.map(event => (
                    <div class="card event-card">
                        <div class="event-date-box">
                            <span class="day">{event.day}</span>
                            <span class="month">{event.month}</span>
                        </div>
                        <div class="event-content">
                            <div class="tag-row">
                                <span class={`tag-pill ${event.tagType}`}>{event.tag}</span>
                                {event.tagType === 'partner' && <span class="tag-pill in-person">In Person</span>}
                            </div>
                            <h3>{event.title}</h3>
                            <div class="event-info-row">
                                <div class="info-item">
                                    <i data-lucide="clock"></i>
                                    <span>{event.time}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide={event.tagType === 'remote' ? 'video' : 'map-pin'}></i>
                                    <span>{event.location}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide="users"></i>
                                    <span>{event.audience}</span>
                                </div>
                            </div>
                            <p class="muted event-description">{event.description}</p>
                        </div>
                        <div class="event-action">
                            {event.private ? (
                                <span class="btn btn--ghost btn--disabled">Private event</span>
                            ) : event.active ? (
                                <a href={event.link} class="btn btn--accent" target="_blank" rel="noopener">Register now</a>
                            ) : (
                                <span class="btn btn--ghost btn--disabled">Coming soon</span>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- FINISHED -->
    <section id="finished" class="section--tight divide">
        <div class="wrap">
            <h2 class="events-head">Finished</h2>

            <div class="events-grid">
                {finishedEvents.map(event => (
                    <div class="card event-card event-card--finished">
                        <div class="event-date-box">
                            <span class="day">{event.day}</span>
                            <span class="month">{event.month}</span>
                        </div>
                        <div class="event-content">
                            <div class="tag-row">
                                <span class={`tag-pill ${event.tagType}`}>{event.tag}</span>
                                {event.tagType === 'partner' && <span class="tag-pill in-person">In Person</span>}
                            </div>
                            <h3>{event.title}</h3>
                            <div class="event-info-row">
                                <div class="info-item">
                                    <i data-lucide="clock"></i>
                                    <span>{event.time}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide={event.tagType === 'remote' ? 'video' : 'map-pin'}></i>
                                    <span>{event.location}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide="users"></i>
                                    <span>{event.audience}</span>
                                </div>
                            </div>
                            <p class="muted event-description">{event.description}</p>
                        </div>
                        <div class="event-action">
                            <span class="btn btn--ghost btn--disabled">Event ended</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-band">
        <div class="wrap wrap--mid cta-inner">
            <h2>Want the best things before they fill up?</h2>
            <p class="lead">One email a month. No spam. Just the best founder opportunities in NI.</p>
            <a href="/#newsletter" class="btn btn--accent">Get the monthly email</a>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 3.5rem; }
    .hero h1 { margin: 1.25rem 0 1.5rem; }
    .hero-lead { max-width: 600px; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3rem; }

    /* PARTNER STRIP */
    .partner-strip { padding: 1.75rem 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-subtle); }
    .strip-label { display: block; margin-bottom: 1.25rem; color: var(--ink-muted); }
    .partner-logos-wrapper {
        overflow: hidden;
        position: relative;
        mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
    .partner-logos {
        display: flex;
        align-items: center;
        gap: 3rem;
        width: max-content;
        animation: scroll 30s linear infinite;
    }
    .partner-logos:hover { animation-play-state: paused; }
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .partner-logo {
        height: 28px;
        width: auto;
        object-fit: contain;
        filter: grayscale(100%);
        opacity: 0.65;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }
    .partner-logo:hover { filter: grayscale(0%); opacity: 1; }
    .partner-logo.invert { filter: grayscale(100%) invert(1); }
    .partner-logo.invert:hover { filter: grayscale(0%) invert(1); }

    /* EVENTS */
    .events-head { margin-bottom: 0.75rem; }
    .events-note { margin-bottom: 2.5rem; }
    .events-grid { display: flex; flex-direction: column; gap: 1.25rem; }

    .event-card {
        display: grid;
        grid-template-columns: 110px 1fr auto;
        gap: 2rem;
        align-items: center;
    }
    .event-card--finished { opacity: 0.75; }
    .event-card--finished:hover { transform: none; box-shadow: none; border-color: var(--line); }

    .event-date-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: var(--bg-subtle);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1rem;
        min-height: 96px;
    }
    .event-date-box .day { font-size: 2rem; font-weight: 800; color: var(--accent); line-height: 1; letter-spacing: -0.02em; }
    .event-date-box .month { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-muted); margin-top: 0.3rem; letter-spacing: 0.12em; text-transform: uppercase; }

    .event-content { display: flex; flex-direction: column; gap: 0.65rem; }
    .event-content h3 { font-size: 1.35rem; margin: 0; }

    .tag-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .tag-pill {
        display: inline-flex;
        align-items: center;
        padding: 3px 11px;
        border-radius: 999px;
        font-family: var(--mono);
        font-size: 0.66rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }
    .tag-pill.remote { background: #eeebfb; color: #5a4bd1; }
    .tag-pill.in-person { background: var(--accent-soft); color: var(--accent); }
    .tag-pill.partner { background: var(--bg-sunken); color: var(--ink-soft); border: 1px solid var(--line); }

    .event-info-row { display: flex; flex-wrap: wrap; gap: 1.25rem; }
    .info-item { display: flex; align-items: center; gap: 0.45rem; font-family: var(--mono); font-size: 0.8rem; color: var(--ink-muted); }
    .info-item i { width: 15px; height: 15px; color: var(--accent); }

    .event-description { font-size: 0.95rem; line-height: 1.55; }

    .event-action .btn { min-width: 150px; font-size: 0.88rem; padding: 0.7rem 1.3rem; }

    /* CTA BAND */
    .cta-band { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .cta-band h2 { color: var(--bg); max-width: 22ch; }
    .cta-band .lead { color: rgba(255,255,255,0.7); }

    @media (max-width: 820px) {
        .hero-photo { aspect-ratio: 16 / 10; }
        .event-card { grid-template-columns: 1fr; gap: 1.25rem; }
        .event-date-box { flex-direction: row; min-height: auto; padding: 0.5rem 1rem; gap: 0.75rem; align-self: flex-start; }
        .event-date-box .month { margin-top: 0; }
        .event-action .btn { width: 100%; }
    }
</style>
