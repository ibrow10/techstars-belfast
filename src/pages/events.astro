---
import BaseLayout from '../layouts/BaseLayout.astro';
import eventsFeed from '../data/events-feed.json';

// Feed is read-only input regenerated by a sibling system. Do not hand-edit.
// Finished/upcoming and day/month display are derived from each event's ISO
// date compared against the build-time clock, not hand-maintained flags.
const buildDate = new Date();
const today = new Date(buildDate.getFullYear(), buildDate.getMonth(), buildDate.getDate());

const parseEventDate = (isoDate) => {
    const [year, month, day] = isoDate.split('-').map(Number);
    return new Date(year, month - 1, day);
};

const events = eventsFeed.map((e) => {
    const eventDate = parseEventDate(e.date);
    return {
        ...e,
        location: e.venue,
        active: Boolean(e.link),
        finished: eventDate < today,
        day: String(eventDate.getDate()).padStart(2, '0'),
        month: eventDate.toLocaleString('en-GB', { month: 'short' }).toUpperCase(),
        sortValue: eventDate.getTime(),
    };
});

const upcomingEvents = events.filter(e => !e.finished).sort((a, b) => a.sortValue - b.sortValue);
const finishedEvents = events.filter(e => e.finished).sort((a, b) => b.sortValue - a.sortValue);
---

<BaseLayout title="Events" description="Founder nights, firesides, build days and showcases across Northern Ireland. Good rooms, useful sessions, real talk.">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Events</p>
            <h1>Good rooms.<br /><span class="accent">Real talk.</span></h1>
            <p class="lead hero-lead">
                Founders don't need more panels. They need people who'll tell the truth.
            </p>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-78.jpg" alt="Founders networking at a Techstars Belfast event" class="hero-photo" />
        </div>
    </section>

    <!-- PARTNER STRIP -->
    <section class="partner-strip">
        <div class="wrap">
            <p class="eyebrow strip-label">Who we've run events with</p>
            <div class="partner-logos-wrapper">
                <div class="partner-logos">
                    <img src="/images/openai.png" alt="OpenAI" class="partner-logo" />
                    <img src="/images/google.png" alt="Google" class="partner-logo" />
                    <img src="/images/stripe.png" alt="Stripe" class="partner-logo" />
                    <img src="/images/aws.png" alt="AWS" class="partner-logo" />
                    <img src="/images/logo-base.png" alt="Base" class="partner-logo invert" />
                    <img src="/images/generalcatalyst.png" alt="General Catalyst" class="partner-logo" />
                    <img src="/images/frontline.png" alt="Frontline" class="partner-logo" />
                    <img src="/images/earlybird.png" alt="Earlybird" class="partner-logo" />
                    <img src="/images/logo-surevalleyventures.webp" alt="Sure Valley Ventures" class="partner-logo invert" />
                    <img src="/images/dogpatch.png" alt="Dogpatch" class="partner-logo invert" />
                    <img src="/images/the-amp.png" alt="The AMP" class="partner-logo invert" />
                    <!-- Duplicate set for seamless marquee loop -->
                    <img src="/images/openai.png" alt="" aria-hidden="true" class="partner-logo" />
                    <img src="/images/google.png" alt="" aria-hidden="true" class="partner-logo" />
                    <img src="/images/stripe.png" alt="" aria-hidden="true" class="partner-logo" />
                    <img src="/images/aws.png" alt="" aria-hidden="true" class="partner-logo" />
                    <img src="/images/logo-base.png" alt="" aria-hidden="true" class="partner-logo invert" />
                    <img src="/images/generalcatalyst.png" alt="" aria-hidden="true" class="partner-logo" />
                    <img src="/images/frontline.png" alt="" aria-hidden="true" class="partner-logo" />
                    <img src="/images/earlybird.png" alt="" aria-hidden="true" class="partner-logo" />
                    <img src="/images/logo-surevalleyventures.webp" alt="" aria-hidden="true" class="partner-logo invert" />
                    <img src="/images/dogpatch.png" alt="" aria-hidden="true" class="partner-logo invert" />
                    <img src="/images/the-amp.png" alt="" aria-hidden="true" class="partner-logo invert" />
                </div>
            </div>
        </div>
    </section>

    <!-- UPCOMING -->
    <section id="upcoming" class="section--tight">
        <div class="wrap">
            <h2 class="events-head">Upcoming events</h2>
            <p class="muted events-note">Everything upcoming is below. If it's full, join the list anyway. We run these often.</p>

            <div class="events-grid">
                {upcomingEvents.map(event => (
                    <div class="card event-card">
                        <div class="event-date-box">
                            <span class="day">{event.day}</span>
                            <span class="month">{event.month}</span>
                        </div>
                        <div class="event-content">
                            <div class="tag-row">
                                <span class={`tag-pill ${event.tagType}`}>{event.tag}</span>
                                {event.tagType === 'partner' && <span class="tag-pill in-person">In Person</span>}
                            </div>
                            <h3>{event.title}</h3>
                            <div class="event-info-row">
                                <div class="info-item">
                                    <i data-lucide="clock"></i>
                                    <span>{event.time}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide={event.tagType === 'remote' ? 'video' : 'map-pin'}></i>
                                    <span>{event.location}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide="users"></i>
                                    <span>{event.audience}</span>
                                </div>
                            </div>
                            <p class="muted event-description">{event.description}</p>
                        </div>
                        <div class="event-action">
                            {event.private ? (
                                <span class="btn btn--ghost btn--disabled">Private event</span>
                            ) : event.active ? (
                                <a href={event.link} class="btn btn--accent" target="_blank" rel="noopener">Register now</a>
                            ) : (
                                <span class="btn btn--ghost btn--disabled">Coming soon</span>
                            )}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- FINISHED -->
    <section id="finished" class="section--tight divide">
        <div class="wrap">
            <h2 class="events-head">Finished events</h2>

            <div class="events-grid">
                {finishedEvents.map(event => (
                    <div class="card event-card event-card--finished">
                        <div class="event-date-box">
                            <span class="day">{event.day}</span>
                            <span class="month">{event.month}</span>
                        </div>
                        <div class="event-content">
                            <div class="tag-row">
                                <span class={`tag-pill ${event.tagType}`}>{event.tag}</span>
                                {event.tagType === 'partner' && <span class="tag-pill in-person">In Person</span>}
                            </div>
                            <h3>{event.title}</h3>
                            <div class="event-info-row">
                                <div class="info-item">
                                    <i data-lucide="clock"></i>
                                    <span>{event.time}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide={event.tagType === 'remote' ? 'video' : 'map-pin'}></i>
                                    <span>{event.location}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide="users"></i>
                                    <span>{event.audience}</span>
                                </div>
                            </div>
                            <p class="muted event-description">{event.description}</p>
                        </div>
                        <div class="event-action">
                            <span class="btn btn--ghost btn--disabled">Event ended</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-band">
        <div class="wrap wrap--mid cta-inner">
            <h2>Want the best things before they fill up?</h2>
            <p class="lead">One email a month. No spam. Just the best founder opportunities in NI.</p>
            <a href="/#newsletter" class="btn btn--accent">Get the monthly email</a>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 3.5rem; }
    .hero h1 { margin: 1.25rem 0 1.5rem; }
    .hero-lead { max-width: 600px; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3rem; }

    /* PARTNER STRIP */
    .partner-strip { padding: 1.75rem 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-subtle); }
    .strip-label { display: block; margin-bottom: 1.25rem; color: var(--ink-muted); }
    .partner-logos-wrapper {
        overflow: hidden;
        position: relative;
        mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }
    .partner-logos {
        display: flex;
        align-items: center;
        gap: 3rem;
        width: max-content;
        animation: scroll 30s linear infinite;
    }
    .partner-logos:hover { animation-play-state: paused; }
    @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }
    .partner-logo {
        height: 28px;
        width: auto;
        object-fit: contain;
        filter: grayscale(100%);
        opacity: 0.65;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }
    .partner-logo:hover { filter: grayscale(0%); opacity: 1; }
    /* White logo files need inverting to read on the light background */
    .partner-logo.invert { filter: grayscale(100%) invert(1); }
    .partner-logo.invert:hover { filter: grayscale(0%) invert(1); }

    /* EVENTS */
    .events-head { margin-bottom: 0.75rem; }
    .events-note { margin-bottom: 2.5rem; }
    .events-grid { display: flex; flex-direction: column; gap: 1.25rem; }

    .event-card {
        display: grid;
        grid-template-columns: 110px 1fr auto;
        gap: 2rem;
        align-items: center;
    }
    .event-card--finished { opacity: 0.75; }
    .event-card--finished:hover { transform: none; box-shadow: none; border-color: var(--line); }

    .event-date-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: var(--bg-subtle);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1rem;
        min-height: 96px;
    }
    .event-date-box .day { font-size: 2rem; font-weight: 800; color: var(--accent); line-height: 1; letter-spacing: -0.02em; }
    .event-date-box .month { font-family: var(--mono); font-size: 0.72rem; color: var(--ink-muted); margin-top: 0.3rem; letter-spacing: 0.12em; text-transform: uppercase; }

    .event-content { display: flex; flex-direction: column; gap: 0.65rem; }
    .event-content h3 { font-size: 1.35rem; margin: 0; }

    .tag-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .tag-pill {
        display: inline-flex;
        align-items: center;
        padding: 3px 11px;
        border-radius: 999px;
        font-family: var(--mono);
        font-size: 0.66rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }
    .tag-pill.remote { background: #eeebfb; color: #5a4bd1; }
    .tag-pill.in-person { background: var(--accent-soft); color: var(--accent); }
    .tag-pill.partner { background: var(--bg-sunken); color: var(--ink-soft); border: 1px solid var(--line); }

    .event-info-row { display: flex; flex-wrap: wrap; gap: 1.25rem; }
    .info-item { display: flex; align-items: center; gap: 0.45rem; font-family: var(--mono); font-size: 0.8rem; color: var(--ink-muted); }
    .info-item i { width: 15px; height: 15px; color: var(--accent); }

    .event-description { font-size: 0.95rem; line-height: 1.55; }

    .event-action .btn { min-width: 150px; font-size: 0.88rem; padding: 0.7rem 1.3rem; }

    /* CTA BAND */
    .cta-band { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .cta-band h2 { color: var(--bg); max-width: 22ch; }
    .cta-band .lead { color: rgba(255,255,255,0.7); }

    @media (max-width: 900px) {
        .hero-photo { aspect-ratio: 16 / 10; }
        .event-card { grid-template-columns: 1fr; gap: 1.25rem; }
        .event-date-box { flex-direction: row; min-height: auto; padding: 0.5rem 1rem; gap: 0.75rem; align-self: flex-start; }
        .event-date-box .month { margin-top: 0; }
    }

    @media (max-width: 600px) {
        .event-action .btn { width: 100%; }
    }
</style>
