---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thanks">
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Waitlist</p>
            <h1>You're <span class="accent">in.</span></h1>
            <p class="lead hero-lead">Thanks for signing up. We'll keep you in the loop as soon as the monthly email goes live.</p>
        </div>
    </section>

    <section class="section--tight">
        <div class="wrap wrap--mid">
            <div class="card thanks-card">
                <p class="thanks-title">Thanks, you're on the waitlist.</p>
                <p class="muted">Expect a welcome note and the best founder opportunities in Northern Ireland.</p>
                <a href="/" class="btn btn--accent">Back to the site</a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 2rem; }
    .hero h1 { margin: 1.25rem 0 1.5rem; }
    .hero-lead { max-width: 600px; }

    .thanks-card { display: grid; gap: 1rem; justify-items: start; }
    .thanks-title { font-size: 1.3rem; font-weight: 700; }
</style>
