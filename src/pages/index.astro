---
import BaseLayout from '../layouts/BaseLayout.astro';
import eventsFeed from '../data/events-feed.json';

const applyUrl = 'https://www.techstars.com/techstars-founder-catalyst-global-fall-2026-program';

// Feed is read-only input regenerated by a sibling system. Do not hand-edit.
// Feature the soonest upcoming event; if nothing is upcoming, fall back to
// the most recent past event, clearly marked as past (never "REGISTER NOW"
// on a dead event).
const buildDate = new Date();
const today = new Date(buildDate.getFullYear(), buildDate.getMonth(), buildDate.getDate());

const parseEventDate = (isoDate) => {
    const [year, month, day] = isoDate.split('-').map(Number);
    return new Date(year, month - 1, day);
};

const sortedEvents = [...eventsFeed].sort((a, b) => parseEventDate(a.date) - parseEventDate(b.date));
const upcomingEvents = sortedEvents.filter(e => parseEventDate(e.date) >= today);
const pastEvents = sortedEvents.filter(e => parseEventDate(e.date) < today).reverse();

const rawFeaturedEvent = upcomingEvents[0] ?? pastEvents[0] ?? null;
const featuredIsPast = rawFeaturedEvent ? parseEventDate(rawFeaturedEvent.date) < today : false;

const latestEvent = rawFeaturedEvent && {
    ...rawFeaturedEvent,
    location: rawFeaturedEvent.venue,
    day: String(parseEventDate(rawFeaturedEvent.date).getDate()).padStart(2, '0'),
    month: parseEventDate(rawFeaturedEvent.date).toLocaleString('en-GB', { month: 'short' }).toUpperCase(),
};

const startHereCards = [
    {
        title: 'Come to an event',
        description: 'Meet founders. Learn something useful. Leave with energy.',
        cta: 'View events',
        link: '/events',
        img: '/images/photos/pic-16.jpg',
        alt: 'Founders laughing at a Techstars Belfast founder night'
    },
    {
        title: 'Join a sprint',
        description: 'Time-boxed build sessions. Ship something real.',
        cta: 'See sprints',
        link: '/sprints',
        img: '/images/photos/pic-227.jpg',
        alt: 'Teams building at a Techstars Belfast sprint'
    },
    {
        title: 'Partner',
        description: 'Back the next wave of NI founders. Sponsor events, sprints, or sign on as a Founding Partner.',
        cta: 'See ways to partner',
        link: '/partners',
        img: '/images/photos/pic-64.jpg',
        alt: 'Speakers on stage at the Techstars Community Development Lab Belfast'
    }
];

---

<BaseLayout description="A founder community and pre-accelerator in Northern Ireland. Events, sprints, and Founder Catalyst, backed by Coinbase, Stripe, and ElevenLabs.">
    <!-- Hero -->
    <section class="hero">
        <div class="wrap">
            <p class="eyebrow">Northern Ireland × Techstars</p>
            <h1>Build here.<br /><span class="accent">Ship everywhere.</span></h1>

            <p class="lead hero-tagline">
                No startup tourism. A founder-led network for builders, researchers, and domain experts who want to move fast, with AI-native execution baked in
            </p>

            <div class="hero-ctas">
                <a href={applyUrl} class="btn btn--accent" target="_blank" rel="noopener">Apply for next cohort</a>
                <a href="/events" class="btn btn--ghost">See what's on</a>
            </div>

            <p class="givefirst-quote">We <span class="givefirst">#GiveFirst</span>: help anyone, especially entrepreneurs, without any expectation of getting anything back.</p>

            <img src="/images/photos/pic-90.jpg" alt="A full room at a Techstars Belfast event in Ormeau Labs" class="hero-photo" />
        </div>
    </section>

    <!-- Partnership Section -->
    <section class="partnership-section">
        <div class="wrap partnership-inner">
            <p class="eyebrow">Official Techstars Startup Community Partnership</p>
            <div class="partnership-logos">
                <div class="partner-logo techstars-logo">
                    <img src="/images/techstarsbelfastlogo.png" alt="Techstars Belfast">
                </div>
                <span class="logo-separator">×</span>
                <div class="partner-logo qub-logo">
                    <img src="/images/QUB-Logo.png" alt="Queen's University Belfast">
                </div>
                <span class="logo-separator">×</span>
                <div class="partner-logo ormeau-logo">
                    <img src="/images/ormeau-labs-logo.svg" alt="Ormeau Labs">
                </div>
            </div>
        </div>
    </section>

    <!-- Bill Gurley Quote -->
    <section class="quote-band">
        <div class="wrap wrap--mid">
            <blockquote>
                <p>"The number one way to protect your career from AI is to be the most aggressive user of AI in your field.</p>
                <p class="quote-emphasis">RUN AT IT."</p>
                <cite>— Bill Gurley</cite>
            </blockquote>
        </div>
    </section>

    <!-- Start Here Section -->
    <section class="section start-here-section">
        <div class="wrap">
            <div class="section-head">
                <h2>Choose your <span class="accent">starting point</span></h2>
            </div>

            <div class="start-here-grid">
                {startHereCards.map(card => (
                    <div class="card path-card">
                        <img src={card.img} alt={card.alt} class="path-photo" loading="lazy" />
                        <h3>{card.title}</h3>
                        <p class="muted path-body">{card.description}</p>
                        {card.closed ? (
                            <span class="path-link path-link--disabled">{card.cta}</span>
                        ) : (
                            <a href={card.link} class="path-link">{card.cta} →</a>
                        )}
                    </div>
                ))}
            </div>

            <p class="partner-blurb muted">
                Already running an early-stage initiative? Corporate, investor, university, public sector. We pair our founder community with partners who want to support the next generation of NI builders. Three tiers, founder-first, no sales pitches. <a href="/partners">See how to partner →</a>
            </p>
        </div>
    </section>

    <!-- Ethos Strip -->
    <section class="section--tight ethos divide">
        <div class="wrap wrap--mid">
            <p class="ethos-line">We give first. We move fast. We're here to help founders win.</p>
        </div>
    </section>

    <!-- Next Up (Featured Event) -->
    <section id="events" class="section events-section divide">
        <div class="wrap">
            <div class="section-head">
                <h2>{featuredIsPast ? 'Most recent event' : 'Next up'}</h2>
                <p class="lead section-intro">
                    {featuredIsPast ? 'Nothing on the calendar yet. Here\'s the last one.' : 'Turn up. Bring questions. Leave clearer.'}
                </p>
            </div>

            {latestEvent && (
                <div class="events-grid">
                    <div class={`card event-card ${featuredIsPast ? 'event-card--finished' : ''}`}>
                        <div class="event-date-box">
                            <span class="day">{latestEvent.day}</span>
                            <span class="month">{latestEvent.month}</span>
                        </div>
                        <div class="event-content">
                            <div class="tag-row">
                                <span class={`tag-pill ${latestEvent.tagType}`}>{latestEvent.tag}</span>
                                {featuredIsPast && <span class="tag-pill past">Past event</span>}
                            </div>
                            <h3>{latestEvent.title}</h3>
                            <div class="event-info-row">
                                <div class="info-item">
                                    <i data-lucide="clock"></i>
                                    <span>{latestEvent.time}</span>
                                </div>
                                <div class="info-item">
                                    <i data-lucide="map-pin"></i>
                                    <span>{latestEvent.location}</span>
                                </div>
                            </div>
                            <p class="event-description muted">{latestEvent.description}</p>
                        </div>
                        <div class="event-action">
                            {latestEvent.private ? (
                                <span class="btn btn--ghost btn--disabled">Private event</span>
                            ) : featuredIsPast ? (
                                <span class="btn btn--ghost btn--disabled">Event ended</span>
                            ) : latestEvent.link ? (
                                <a href={latestEvent.link} class="btn btn--accent" target="_blank">Register now</a>
                            ) : (
                                <span class="btn btn--ghost btn--disabled">Coming soon</span>
                            )}
                        </div>
                    </div>
                </div>
            )}

            <div class="view-all-wrapper">
                <a href="/events" class="btn">View all events →</a>
            </div>
        </div>
    </section>

    <!-- Newsletter Section -->
    <section id="newsletter" class="section--tight newsletter divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">The monthly founder email</p>
            <h2 class="newsletter-head">Coming soon, sign up to find out more.</h2>
            <p class="muted newsletter-detail">Early access for events, sprints, programmes, and open calls.</p>
            <form name="newsletter-waitlist" method="POST" action="/thanks" data-netlify="true" netlify-honeypot="bot-field" class="newsletter-form">
                <input type="hidden" name="form-name" value="newsletter-waitlist" />
                <p class="hidden">
                    <label>Don’t fill this out: <input name="bot-field" /></label>
                </p>
                <div class="newsletter-fields">
                    <label class="sr-only" for="newsletter-name">Name</label>
                    <input id="newsletter-name" name="name" type="text" autocomplete="name" placeholder="Your name" required />
                    <label class="sr-only" for="newsletter-email">Email</label>
                    <input id="newsletter-email" name="email" type="email" autocomplete="email" placeholder="Your email" required />
                    <button type="submit" class="btn btn--accent">Join the waitlist</button>
                </div>
                <p class="newsletter-legal">By signing up, you agree to receive the monthly email.</p>
            </form>
        </div>
    </section>

</BaseLayout>

<style>
    /* HERO */
    .hero { padding: 6rem 0 5rem; }
    .hero h1 { margin: 1.25rem 0 1.75rem; }
    .hero-tagline { max-width: 600px; margin-bottom: 2.5rem; }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .givefirst { color: var(--accent); font-weight: 700; }
    .givefirst-quote {
        margin-top: 2rem;
        font-size: 0.95rem;
        color: var(--ink-muted);
        max-width: 600px;
    }
    .hero-photo {
        width: 100%;
        aspect-ratio: 21 / 9;
        object-fit: cover;
        border-radius: 20px;
        margin-top: 3.5rem;
    }

    /* PARTNERSHIP */
    .partnership-section {
        background: var(--bg-subtle);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        padding: 2.5rem 0;
    }
    .partnership-inner { text-align: center; }
    .partnership-inner .eyebrow { margin-bottom: 1.5rem; }
    .partnership-logos {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }
    .logo-separator { color: var(--ink-muted); font-size: 1rem; font-weight: 300; }
    .partner-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.85;
        transition: opacity 0.3s ease;
    }
    .partner-logo:hover { opacity: 1; }
    .techstars-logo img { height: 90px; width: auto; filter: invert(1) hue-rotate(180deg); }
    .qub-logo img { height: 80px; width: auto; }
    .ormeau-logo img { height: 65px; width: auto; }

    /* BILL GURLEY QUOTE */
    .quote-band { background: var(--accent-soft); padding: 5rem 0; }
    .quote-band blockquote { text-align: center; margin: 0; padding: 0; }
    .quote-band blockquote p {
        font-size: clamp(1.3rem, 3vw, 1.75rem);
        line-height: 1.5;
        color: var(--ink);
        margin: 0 0 1rem 0;
        font-weight: 500;
    }
    .quote-emphasis {
        font-size: clamp(2rem, 5vw, 3rem) !important;
        font-weight: 800 !important;
        letter-spacing: -0.02em;
        color: var(--accent) !important;
        margin: 1.5rem 0 !important;
    }
    .quote-band cite {
        display: block;
        font-family: var(--mono);
        font-size: 0.9rem;
        color: var(--ink-muted);
        font-style: normal;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-top: 1.5rem;
    }

    /* SECTION HEADS */
    .section-head { margin-bottom: 3rem; }
    .section-intro { margin-top: 0.75rem; }

    /* START HERE */
    .start-here-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .path-card { display: flex; flex-direction: column; overflow: hidden; padding: 0; }
    .path-card > * { margin-left: 2rem; margin-right: 2rem; }
    .path-card .path-photo { margin: 0 0 1.75rem; width: 100%; aspect-ratio: 3 / 2; object-fit: cover; }
    .path-card h3 { margin-bottom: 0.75rem; font-size: 1.4rem; }
    .path-body { flex-grow: 1; margin-bottom: 1.5rem; font-size: 0.98rem; }
    .path-link { margin-bottom: 2rem; font-weight: 600; color: var(--accent); font-size: 0.95rem; }
    .path-link:hover { opacity: 0.8; }
    .path-link--disabled { color: var(--ink-muted); cursor: default; pointer-events: none; }

    .partner-blurb {
        margin: 3rem auto 0;
        max-width: 760px;
        font-size: 1rem;
        line-height: 1.65;
        text-align: center;
    }
    .partner-blurb a { color: var(--accent); font-weight: 600; white-space: nowrap; }
    .partner-blurb a:hover { opacity: 0.8; }

    /* ETHOS */
    .ethos-line {
        font-size: clamp(1.6rem, 3.2vw, 2.4rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.25;
        color: var(--ink);
        margin: 0;
        text-align: center;
    }

    /* EVENTS */
    .events-grid { display: flex; flex-direction: column; gap: 1.5rem; }
    .event-card {
        display: grid;
        grid-template-columns: 120px 1fr auto;
        gap: 2rem;
        padding: 2rem;
        align-items: center;
    }
    .event-card--finished { opacity: 0.9; }
    .event-card--finished:hover { transform: none; border-color: var(--line); box-shadow: none; }

    .event-date-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: var(--bg-subtle);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1rem;
        min-height: 100px;
    }
    .event-date-box .day {
        font-size: 2rem;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
    }
    .event-date-box .month {
        font-size: 0.75rem;
        color: var(--ink-muted);
        margin-top: 0.35rem;
        letter-spacing: 0.1em;
        font-family: var(--mono);
        text-transform: uppercase;
    }

    .event-content { display: flex; flex-direction: column; gap: 0.75rem; }
    .event-content h3 { font-size: 1.5rem; margin: 0; letter-spacing: -0.02em; }

    .tag-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .tag-pill {
        display: inline-flex;
        align-items: center;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-family: var(--mono);
    }
    .tag-pill.remote { background: #eeebfb; color: #5a4bd1; }
    .tag-pill.in-person { background: var(--accent-soft); color: var(--accent); }
    .tag-pill.partner { background: var(--bg-sunken); color: var(--ink-soft); border: 1px solid var(--line); }
    .tag-pill.past { background: var(--bg-sunken); color: var(--ink-muted); border: 1px solid var(--line); }

    .event-info-row { display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 0.25rem; }
    .info-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        color: var(--ink-soft);
        font-family: var(--mono);
    }
    .info-item i { width: 16px; height: 16px; color: var(--accent); }

    .event-description { font-size: 0.95rem; line-height: 1.55; margin: 0.25rem 0 0; }

    .event-action .btn { min-width: 150px; text-align: center; }

    .view-all-wrapper { margin-top: 3rem; text-align: center; }

    /* NEWSLETTER */
    .newsletter { background: var(--bg-subtle); }
    .newsletter-head { margin: 0.75rem 0; max-width: 26ch; }
    .newsletter-detail { margin-bottom: 2rem; }
    .newsletter-fields { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .newsletter-fields input {
        flex: 1 1 200px;
        padding: 0.85rem 1.2rem;
        font-family: var(--font);
        font-size: 0.95rem;
        border: 1.5px solid var(--line);
        border-radius: 999px;
        background: var(--bg);
        color: var(--ink);
        transition: border-color 0.2s ease;
    }
    .newsletter-fields input::placeholder { color: var(--ink-muted); }
    .newsletter-fields input:focus { outline: none; border-color: var(--accent); }
    .newsletter-legal { font-size: 0.8rem; color: var(--ink-muted); margin-top: 1rem; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
        .start-here-grid { grid-template-columns: 1fr; }
        .hero-photo { aspect-ratio: 16 / 10; }
        .event-card { grid-template-columns: 1fr; gap: 1.5rem; padding: 1.5rem; }
        .event-date-box {
            flex-direction: row;
            min-height: auto;
            padding: 0.5rem 1rem;
            gap: 1rem;
            justify-content: flex-start;
        }
        .event-date-box .month { margin-top: 0; }
    }

    @media (max-width: 600px) {
        .hero-ctas .btn { width: 100%; }
        .event-action .btn { width: 100%; }
        .newsletter-fields .btn { width: 100%; }
        .partnership-logos { gap: 1rem; }
        .techstars-logo img { height: 70px; }
        .qub-logo img { height: 60px; }
        .ormeau-logo img { height: 50px; }
        .logo-separator { font-size: 0.8rem; }
    }
</style>
