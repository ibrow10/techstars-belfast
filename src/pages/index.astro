---
import BaseLayout from '../layouts/BaseLayout.astro';

const paths = [
    {
        label: 'Founder Catalyst',
        title: 'Build a fundable company',
        body: 'A selective pre-accelerator delivered with Techstars. Ten weeks, a global cohort, no equity taken.',
        href: '/programmes',
        cta: 'Apply now',
        img: '/images/photos/pic-130.jpg',
        alt: 'A speaker presenting at a Techstars Belfast session',
    },
    {
        label: 'Sprints',
        title: 'Ship something real',
        body: 'Short, high-intensity build sessions. We run them with universities, funds, corporates and the public sector.',
        href: '/sprints',
        cta: 'Run one with us',
        img: '/images/photos/pic-227.jpg',
        alt: 'Teams working at tables during a Techstars Belfast build sprint',
    },
    {
        label: 'Community',
        title: 'Meet the room',
        body: 'Events and founder nights across Northern Ireland. Turn up, bring questions, leave with momentum.',
        href: '/events',
        cta: "See what's on",
        img: '/images/photos/pic-16.jpg',
        alt: 'Founders laughing together at a Techstars Belfast founder night',
    },
];
---

<BaseLayout>
    <!-- HERO -->
    <section class="hero">
        <div class="wrap">
            <p class="eyebrow">Northern Ireland × Techstars</p>
            <h1>Build here.<br /><span class="accent">Connect everywhere.</span></h1>
            <p class="lead hero-lead">
                Techstars Belfast plugs Northern Ireland's founders into one of the world's
                biggest startup networks. Start where you are. Compete with anyone.
            </p>
            <div class="hero-ctas">
                <a href="/programmes" class="btn btn--accent">Apply to Founder Catalyst</a>
                <a href="/sprints" class="btn btn--ghost">Run a sprint</a>
            </div>
            <img src="/images/photos/pic-90.jpg" alt="A full room at a Techstars Belfast event in Ormeau Labs" class="hero-photo" />
        </div>
    </section>

    <!-- NETWORK PROOF -->
    <section class="proof">
        <div class="wrap proof-inner">
            <div class="proof-stat">
                <span class="proof-num">10,000+</span>
                <span class="proof-label">founders in the network</span>
            </div>
            <div class="proof-stat">
                <span class="proof-num">150+</span>
                <span class="proof-label">countries</span>
            </div>
            <div class="proof-stat">
                <span class="proof-num">$130B+</span>
                <span class="proof-label">market cap of Techstars companies</span>
            </div>
            <div class="proof-stat">
                <span class="proof-num">2006</span>
                <span class="proof-label">backing founders since</span>
            </div>
        </div>
    </section>

    <!-- THREE PATHS -->
    <section class="section paths">
        <div class="wrap">
            <div class="paths-head">
                <p class="eyebrow">Where to start</p>
                <h2>Three ways in.</h2>
            </div>
            <div class="paths-grid">
                {paths.map(p => (
                    <a href={p.href} class="card path-card">
                        <img src={p.img} alt={p.alt} class="path-photo" loading="lazy" />
                        <p class="eyebrow">{p.label}</p>
                        <h3>{p.title}</h3>
                        <p class="muted path-body">{p.body}</p>
                        <span class="path-link">{p.cta} →</span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <!-- ETHOS -->
    <section class="section ethos divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Why we exist</p>
            <p class="ethos-line">
                The next wave of companies will start here and sell to the world.
                We give founders the network, the pace and the room to make that real.
            </p>
            <p class="ethos-give">We <span class="accent">#GiveFirst</span> — help founders, expecting nothing back. And we collaborate with everyone: universities, funds, corporates, government, community groups.</p>
        </div>
        <div class="wrap ethos-strip">
            <img src="/images/photos/pic-31.jpg" alt="Founders networking at a Techstars Belfast event" loading="lazy" />
            <img src="/images/photos/pic-206.jpg" alt="Founders in conversation at a Techstars Belfast session" loading="lazy" />
            <img src="/images/photos/pic-308.jpg" alt="A founder presenting to the room at a Techstars Belfast workshop" loading="lazy" />
        </div>
    </section>

    <!-- NEWSLETTER -->
    <section id="newsletter" class="section--tight newsletter divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">The monthly founder email</p>
            <h2 class="newsletter-head">The best founder opportunities in NI. Once a month.</h2>
            <p class="muted newsletter-detail">Early access for events, sprints, programmes, and open calls. No spam.</p>
            <form name="newsletter-waitlist" method="POST" action="/thanks" data-netlify="true" netlify-honeypot="bot-field" class="newsletter-form">
                <input type="hidden" name="form-name" value="newsletter-waitlist" />
                <p class="hidden">
                    <label>Don’t fill this out: <input name="bot-field" /></label>
                </p>
                <div class="newsletter-fields">
                    <label class="sr-only" for="newsletter-name">Name</label>
                    <input id="newsletter-name" name="name" type="text" autocomplete="name" placeholder="Your name" required />
                    <label class="sr-only" for="newsletter-email">Email</label>
                    <input id="newsletter-email" name="email" type="email" autocomplete="email" placeholder="Your email" required />
                    <button type="submit" class="btn btn--accent">Join the waitlist</button>
                </div>
                <p class="newsletter-legal">By signing up, you agree to receive the monthly email.</p>
            </form>
        </div>
    </section>

    <!-- CTA BAND -->
    <section class="cta-band">
        <div class="wrap wrap--mid cta-inner">
            <h2>Ready to build something that competes globally?</h2>
            <p class="lead">Founder Catalyst applications are open.</p>
            <a href="/programmes" class="btn btn--accent">Apply now</a>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 5rem; }
    .hero h1 { margin: 1.25rem 0 1.75rem; }
    .hero-lead { max-width: 600px; margin-bottom: 2.5rem; }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-photo {
        width: 100%;
        aspect-ratio: 21 / 9;
        object-fit: cover;
        border-radius: 20px;
        margin-top: 3.5rem;
    }

    /* PROOF */
    .proof { border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); background: var(--bg-subtle); }
    .proof-inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; padding: 3rem 1.5rem; }
    .proof-stat { display: flex; flex-direction: column; gap: 0.4rem; }
    .proof-num { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 800; letter-spacing: -0.03em; color: var(--ink); }
    .proof-label { font-size: 0.85rem; color: var(--ink-muted); line-height: 1.4; }

    /* PATHS */
    .paths-head { margin-bottom: 3rem; }
    .paths-head h2 { margin-top: 0.75rem; }
    .paths-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .path-card { display: flex; flex-direction: column; overflow: hidden; padding: 0; }
    .path-card > * { margin-left: 2rem; margin-right: 2rem; }
    .path-card .path-photo { margin: 0 0 1.75rem; width: 100%; aspect-ratio: 3 / 2; object-fit: cover; }
    .path-card .path-link { margin-bottom: 2rem; }
    .path-card h3 { margin-top: 0.75rem; margin-bottom: 0.75rem; font-size: 1.4rem; }
    .path-body { flex-grow: 1; margin-bottom: 1.5rem; font-size: 0.98rem; }
    .path-link { font-weight: 600; color: var(--accent); font-size: 0.95rem; }

    /* ETHOS */
    .ethos-line { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 700; letter-spacing: -0.025em; line-height: 1.25; margin: 1.25rem 0 2rem; }
    .ethos-give { font-size: 1.05rem; color: var(--ink-soft); }
    .ethos-give .accent { font-weight: 700; }
    .ethos-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 4rem; }
    .ethos-strip img { width: 100%; aspect-ratio: 4 / 3; object-fit: cover; border-radius: 16px; }

    /* NEWSLETTER */
    .newsletter { background: var(--bg-subtle); }
    .newsletter-head { margin: 0.75rem 0 0.75rem; max-width: 24ch; }
    .newsletter-detail { margin-bottom: 2rem; }
    .newsletter-fields { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .newsletter-fields input {
        flex: 1 1 200px;
        padding: 0.85rem 1.2rem;
        font-family: var(--font);
        font-size: 0.95rem;
        border: 1.5px solid var(--line);
        border-radius: 999px;
        background: var(--bg);
        color: var(--ink);
        transition: border-color var(--t);
    }
    .newsletter-fields input:focus { outline: none; border-color: var(--accent); }
    .newsletter-legal { font-size: 0.8rem; color: var(--ink-muted); margin-top: 1rem; }

    /* CTA BAND */
    .cta-band { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .cta-band h2 { color: var(--bg); max-width: 18ch; }
    .cta-band .lead { color: rgba(255,255,255,0.7); }
    .cta-band .btn--accent { margin-top: 0.5rem; }

    @media (max-width: 900px) {
        .proof-inner { grid-template-columns: repeat(2, 1fr); }
        .paths-grid { grid-template-columns: 1fr; }
        .ethos-strip { grid-template-columns: 1fr; }
        .hero-photo { aspect-ratio: 16 / 10; }
    }
    @media (max-width: 600px) {
        .hero-ctas .btn { width: 100%; }
        .newsletter-fields .btn { width: 100%; }
    }
</style>
