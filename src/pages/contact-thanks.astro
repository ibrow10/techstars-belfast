---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Message received">
    <section class="thanks-hero">
        <div class="container">
            <span class="page-label">GET IN TOUCH</span>
            <h1>MESSAGE RECEIVED.</h1>
            <p class="hero-tagline">Thanks for reaching out. We read every message and will come back to you soon.</p>
        </div>
    </section>

    <section class="thanks-section">
        <div class="container">
            <div class="thanks-card">
                <p class="thanks-title">We've got it.</p>
                <p class="thanks-detail">Someone from the Techstars Belfast team will be in touch. In the meantime, take a look at what's coming up.</p>
                <div class="thanks-actions">
                    <a href="/events" class="btn btn--accent">See upcoming events</a>
                    <a href="/" class="btn btn--outline">Back to the site</a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .thanks-hero {
        position: relative;
        padding: 7rem 0 3rem;
        border-bottom: 1px solid var(--border-color);
        background: radial-gradient(circle at 15% 20%, rgba(255, 255, 255, 0.08), transparent 45%),
            radial-gradient(circle at 80% 0%, rgba(0, 210, 106, 0.08), transparent 40%);
    }
    .thanks-hero .container { max-width: 1000px; }
    .page-label {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-color);
        margin-bottom: 1rem;
    }
    .thanks-hero h1 {
        margin: 1rem 0;
        font-size: clamp(2.4rem, 4vw, 3.6rem);
        letter-spacing: 0.02em;
    }
    .hero-tagline { max-width: 640px; color: #cfcfcf; font-size: 1.1rem; }
    .thanks-section { padding: 4rem 0 6rem; }
    .thanks-section .container { max-width: 900px; }
    .thanks-card {
        background: #0a0a0a;
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 3rem;
        display: grid;
        gap: 1rem;
    }
    .thanks-title { font-size: 1.4rem; font-weight: 600; color: #fff; margin: 0; }
    .thanks-detail { font-size: 1rem; color: #a9a9a9; margin: 0; }
    .thanks-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }
    @media (max-width: 768px) {
        .thanks-hero { padding: 6rem 0 2.5rem; }
        .thanks-card { padding: 2rem; }
    }
</style>
