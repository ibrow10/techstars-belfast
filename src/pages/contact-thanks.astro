---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Message received">
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Get in touch</p>
            <h1>Message <span class="accent">received.</span></h1>
            <p class="lead hero-lead">Thanks for reaching out. We read every message and will come back to you soon.</p>
        </div>
    </section>

    <section class="section--tight">
        <div class="wrap wrap--mid">
            <div class="card thanks-card">
                <p class="thanks-title">We've got it.</p>
                <p class="muted">Someone from the Techstars Belfast team will be in touch. In the meantime, take a look at what's coming up.</p>
                <div class="thanks-actions">
                    <a href="/events" class="btn btn--accent">See upcoming events</a>
                    <a href="/" class="btn btn--ghost">Back to the site</a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 2rem; }
    .hero h1 { margin: 1.25rem 0 1.5rem; }
    .hero-lead { max-width: 600px; }

    .thanks-card {
        display: grid;
        gap: 1rem;
        justify-items: start;
    }
    .thanks-title {
        font-size: 1.3rem;
        font-weight: 700;
    }
    .thanks-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    @media (max-width: 600px) {
        .thanks-actions {
            flex-direction: column;
            align-self: stretch;
            width: 100%;
        }
        .thanks-actions .btn {
            width: 100%;
            text-align: center;
        }
    }
</style>
