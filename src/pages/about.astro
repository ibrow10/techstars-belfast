---
import BaseLayout from '../layouts/BaseLayout.astro';

const stack = [
    { t: 'Events', d: 'Founder nights and high-signal sessions across NI.' },
    { t: 'Sprints', d: 'Time-boxed builds. Ship in hours and days, not weeks.' },
    { t: 'Founder Catalyst', d: 'A Techstars pre-accelerator pathway. No equity taken.' },
];

const principles = [
    'Founders first',
    'Ship fast',
    'Global ambition, local roots',
    'Give first',
];
---

<BaseLayout title="About" description="Techstars Belfast is Northern Ireland's founder community, delivered with Queen's University Belfast and Ormeau Labs, connected to the global Techstars network.">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">About</p>
            <h1>Northern Ireland's<br /><span class="accent">founder community.</span></h1>
            <p class="lead hero-lead">
                Founder-led. Delivered with Queen's University Belfast and Ormeau Labs.
                Connected to the global Techstars network. Build here. Connect everywhere.
            </p>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-47.jpg" alt="Speakers and partners on stage at the Techstars Community Development Lab Belfast" class="hero-photo" />
        </div>
    </section>

    <!-- THE STACK -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">What we run</p>
            <h2 class="stack-head">Not one programme. A stack.</h2>
            <div class="stack">
                {stack.map(s => (
                    <div class="stack-row">
                        <h3>{s.t}</h3>
                        <p class="muted">{s.d}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- TECHSTARS -->
    <section class="section--tight band">
        <div class="wrap wrap--mid">
            <p class="band-line">
                Techstars has backed founders since 2006 — 10,000+ companies, 150+ countries,
                $130B+ in market cap. Techstars Belfast is your on-ramp into it.
            </p>
        </div>
    </section>

    <!-- PARTNERS -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Built with</p>
            <h2 class="partners-head">Two anchor partners.</h2>
            <div class="partners">
                <div class="partner">
                    <img src="/images/photos/pic-114.jpg" alt="The Queen's University Belfast Student Hub" class="partner-photo" loading="lazy" />
                    <h3>Queen's University Belfast</h3>
                    <p class="muted">Research depth, talent, and a long commitment to spinouts and commercialisation. The next breakout companies come from people closest to frontier knowledge.</p>
                </div>
                <div class="partner">
                    <img src="/images/photos/pic-90.jpg" alt="A Techstars Belfast event filling the room at Ormeau Labs" class="partner-photo" loading="lazy" />
                    <h3>Ormeau Labs</h3>
                    <p class="muted">A central hub for Belfast founders. Communities aren't built on strategy documents — they're built through repeated collisions in rooms full of builders.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- PRINCIPLES -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">How we operate</p>
            <div class="principles">
                {principles.map(p => <span class="principle">{p}</span>)}
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta">
        <div class="wrap wrap--mid cta-inner">
            <h2>Start where you are.</h2>
            <div class="cta-ctas">
                <a href="/programmes" class="btn btn--accent">Apply to Founder Catalyst</a>
                <a href="/sprints" class="btn btn--ghost btn--ghost-dark">Run a sprint</a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 4rem; }
    .hero h1 { margin: 1.25rem 0 1.75rem; }
    .hero-lead { max-width: 600px; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3.5rem; }

    .partner-photo { width: 100%; aspect-ratio: 3 / 2; object-fit: cover; border-radius: 16px; margin-bottom: 1.25rem; }

    .stack-head, .partners-head { margin: 0.75rem 0 2.5rem; }
    .stack { display: flex; flex-direction: column; }
    .stack-row { display: grid; grid-template-columns: 240px 1fr; gap: 2rem; padding: 1.75rem 0; border-top: 1px solid var(--line); align-items: baseline; }
    .stack-row:last-child { border-bottom: 1px solid var(--line); }
    .stack-row h3 { font-size: 1.3rem; }

    .band { background: var(--accent-soft); }
    .band-line { font-size: clamp(1.2rem, 2.4vw, 1.6rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.4; color: #0a3d24; }

    .partners { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .partner h3 { margin-bottom: 0.75rem; }
    .partner p { font-size: 0.98rem; line-height: 1.6; }

    .principles { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
    .principle { font-size: 1rem; font-weight: 500; padding: 0.7rem 1.3rem; border: 1px solid var(--line); border-radius: 999px; }

    .cta { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.75rem; }
    .cta h2 { color: var(--bg); }
    .cta-ctas { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
    .btn--ghost-dark { color: var(--bg); border-color: rgba(255,255,255,0.3); }
    .btn--ghost-dark:hover { background: rgba(255,255,255,0.1); }

    @media (max-width: 760px) {
        .stack-row { grid-template-columns: 1fr; gap: 0.5rem; }
        .partners { grid-template-columns: 1fr; gap: 2rem; }
        .cta-ctas .btn { width: 100%; }
        .hero-photo { aspect-ratio: 16 / 10; }
    }
</style>
