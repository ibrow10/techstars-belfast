---
import BaseLayout from '../layouts/BaseLayout.astro';

const stack = [
    {
        icon: 'calendar',
        title: 'Events & founder nights',
        description: 'Meet peers, learn fast, build momentum'
    },
    {
        icon: 'zap',
        title: 'Sprints',
        description: 'Our AI-era evolution of Startup Weekend: ship in hours/days, not weeks'
    },
    {
        icon: 'rocket',
        title: 'Founder Catalyst',
        description: 'A structured pre-accelerator pathway delivered through Techstars'
    },
    {
        icon: 'users',
        title: 'Community Development Lab',
        description: 'Coordinated ecosystem action (with founders in the room first)'
    }
];

const whyNowPoints = [
    'how products are built (speed, tooling, smaller teams)',
    'which markets are accessible (global from day one)',
    'which jobs and industries get disrupted (workflow-heavy sectors in particular)'
];

const weNeed = [
    'try building companies earlier',
    'meet collaborators faster',
    'access world-class mentorship and peer networks',
    'develop global ambition without leaving home'
];

const principles = [
    {
        title: 'Founders first',
        description: 'Practical help over theatre.'
    },
    {
        title: 'Ship fast',
        description: 'Working demos beat slides.'
    },
    {
        title: 'AI-native by default',
        description: 'The future is already here.'
    },
    {
        title: 'Global ambition, local roots',
        description: 'Build from here. Ship everywhere.'
    },
    {
        title: 'Be optimistic',
        description: 'Believe in what\'s possible.'
    },
    {
        title: 'Give First',
        description: 'Help without expecting anything in return.'
    }
];
---

<BaseLayout title="About">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">About</p>
            <h1>Northern Ireland's<br /><span class="accent">founder community.</span></h1>
            <p class="hero-tagline">Build here. Ship everywhere.</p>
            <p class="lead hero-lead">
                Techstars Belfast is a founder-led startup community for Northern Ireland, delivered with Queen's University Belfast and Ormeau Labs, connecting ambitious local builders into the global Techstars platform and network.
            </p>
            <p class="muted hero-sub">
                We run high-signal events, build sprints, and early-stage programmes designed for the pace of the AI era.
            </p>
            <p class="hero-ethos">This is not about "innovation". <span class="accent">It's about founders.</span></p>
            <div class="hero-ctas">
                <a href="/partners" class="btn">Partner with us</a>
                <a href="https://techstarsbelfast.com/founder-report/" class="btn btn--ghost">Read the State of the Nation</a>
            </div>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-47.jpg" alt="Speakers and partners on stage at the Techstars Community Development Lab Belfast" class="hero-photo" />
        </div>
    </section>

    <!-- WHO ARE TECHSTARS -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">The network</p>
            <h2 class="section-head">Who are <span class="accent">Techstars?</span></h2>
            <p class="lead">Techstars is one of the world's most recognised startup networks: a founder-first organisation that runs mentorship-driven accelerators, invests in early-stage companies, and supports startup communities globally.</p>
            <p class="mission">Their mission is simple: <span class="accent">help founders succeed.</span></p>
            <div class="stats-row">
                <div class="stat-item">
                    <span class="stat-number">2006</span>
                    <span class="stat-label">Founded</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">5,000+</span>
                    <span class="stat-label">Companies invested</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">$130.6B+</span>
                    <span class="stat-label">Market cap</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">Global</span>
                    <span class="stat-label">Founder network</span>
                </div>
            </div>
            <p class="muted">Since 2006, Techstars has built a global community of founders, mentors, investors and partners that stays connected long after any single programme ends.</p>
            <p class="muted leader-note">Techstars is led by David Cohen, one of the original founders.</p>
        </div>
    </section>

    <!-- WHAT IS TECHSTARS BELFAST -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">The model</p>
            <h2 class="section-head">What is Techstars <span class="accent">Belfast?</span></h2>
            <p class="lead">Techstars Belfast is Techstars' Startup Community Partnership model, launched in Belfast and built to serve founders across Northern Ireland.</p>
            <p class="muted what-sub">A Startup Community Partnership is designed to help a city or region build a thriving startup community using Techstars' playbooks, programmes and global experience.</p>

            <h3 class="stack-label">In practice, Techstars Belfast is a stack (not a single programme):</h3>
            <div class="stack-grid">
                {stack.map(item => (
                    <div class="card stack-card">
                        <div class="stack-icon">
                            <i data-lucide={item.icon}></i>
                        </div>
                        <div class="stack-text">
                            <strong>{item.title}</strong>
                            <span class="muted">{item.description}</span>
                        </div>
                    </div>
                ))}
            </div>

            <div class="flywheel-block">
                <p class="flywheel-intro">We're building a simple flywheel:</p>
                <p class="flywheel">show up → meet the right people → ship faster → become fundable → recycle back into the community.</p>
            </div>
        </div>
    </section>

    <!-- OUR DNA -->
    <section class="section band">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Our DNA</p>
            <h2 class="dna-headline">Techstars Belfast is <span class="accent">founder-led</span>.</h2>
            <p class="dna-subhead">We're a startup community that behaves like a startup.</p>

            <div class="dna-values">
                <div class="value-block">
                    <p>We move fast. We're comfortable in ambiguity. We occasionally get things wrong.</p>
                    <p class="value-emphasis">When we do, we don't blame anyone. We fix it, learn, and move on.</p>
                </div>

                <div class="value-block">
                    <p>Founders are our customer. We ask <span class="accent">"how can we better help founders?"</span> every day.</p>
                    <p>And we don't care about borders. We're the bridge from Belfast into the UK, Europe and North America.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- OUR PARTNERS -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Built with</p>
            <h2 class="section-head">Our <span class="accent">partners</span></h2>
            <p class="muted partners-intro">Techstars Belfast is delivered with two anchor partners: one rooted in research and talent, one rooted in community and density.</p>

            <div class="partners-grid">
                <div class="partner">
                    <img src="/images/photos/pic-114.jpg" alt="The Queen's University Belfast Student Hub" class="partner-photo" loading="lazy" />
                    <h3>Queen's University Belfast</h3>
                    <p class="muted partner-description">Queen's brings deep research capability, student and postgraduate talent, and a long-standing commitment to entrepreneurship, commercialisation and spinouts through QUBIS and wider innovation programmes.</p>
                    <p class="partner-why"><strong>This matters because</strong> the next wave of breakout companies will come from people closest to frontier knowledge: researchers, PhDs, engineers, and builders who can compete globally.</p>
                </div>

                <div class="partner">
                    <img src="/images/photos/pic-90.jpg" alt="A Techstars Belfast event filling the room at Ormeau Labs" class="partner-photo" loading="lazy" />
                    <h3>Ormeau Labs</h3>
                    <p class="muted partner-description">Ormeau Labs is a central hub for founders in Belfast, a space where startups, freelancers and entrepreneurs build, meet and collaborate.</p>
                    <p class="partner-why"><strong>This matters because</strong> startup communities aren't built on strategy documents. They're built through repeated collisions, shared experiences, and rooms full of builders.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- WHY NOW -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Why now</p>
            <h2 class="section-head">Why this is important <span class="accent">(and why now)</span></h2>
            <p class="lead why-lead">Northern Ireland is at an inflection point.</p>

            <div class="why-block">
                <h3>AI is changing:</h3>
                <ul class="arrow-list">
                    {whyNowPoints.map(point => (
                        <li>{point}</li>
                    ))}
                </ul>
            </div>

            <div class="why-block">
                <h3>If we want Northern Ireland to win, we need more people to:</h3>
                <ul class="arrow-list">
                    {weNeed.map(point => (
                        <li>{point}</li>
                    ))}
                </ul>
            </div>

            <p class="why-conclusion">Techstars Belfast exists to make that real, with practical formats that match modern build velocity, and a network that opens doors beyond our local market.</p>
            <p class="why-tagline">We're building companies that <span class="accent">start here and compete everywhere.</span></p>
        </div>
    </section>

    <!-- HOW TO GET INVOLVED -->
    <section class="section divide">
        <div class="wrap">
            <p class="eyebrow">Get involved</p>
            <h2 class="section-head">How to get <span class="accent">involved</span></h2>

            <div class="involved-grid">
                <div class="card involved-card">
                    <div class="involved-icon">
                        <i data-lucide="rocket"></i>
                    </div>
                    <h3>If you're a founder (or want to be)</h3>
                    <p class="muted">Start with an event. Join a Sprint. Ship something. Momentum is the whole game.</p>
                    <div class="involved-ctas">
                        <a href="/events" class="btn btn--sm">View events</a>
                        <a href="/sprints" class="btn btn--sm btn--ghost">Join a Sprint</a>
                    </div>
                </div>

                <div class="card involved-card">
                    <div class="involved-icon">
                        <i data-lucide="microscope"></i>
                    </div>
                    <h3>If you're a researcher / student / PhD</h3>
                    <p class="muted">This is your on-ramp. Bring a problem, a hypothesis, or a capability, and build in public with people who can help you turn it into a company.</p>
                    <div class="involved-ctas">
                        <a href="/sprints" class="btn btn--sm">Join a Sprint</a>
                        <span class="btn btn--sm btn--ghost btn--disabled">Applications closed</span>
                    </div>
                </div>

                <div class="card involved-card">
                    <div class="involved-icon">
                        <i data-lucide="handshake"></i>
                    </div>
                    <h3>If you're a partner (corporate, investor, organisation)</h3>
                    <p class="muted">Sponsor a Sprint. Host a masterclass. Provide tools/credits. Meet founders early and support the next generation of companies in Northern Ireland.</p>
                    <div class="involved-ctas">
                        <a href="/partners" class="btn btn--sm">Partner with us</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- OPERATING PRINCIPLES -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">How we operate</p>
            <h2 class="section-head">Our operating <span class="accent">principles</span></h2>
            <div class="principles-grid">
                {principles.map(principle => (
                    <div class="principle-card">
                        <h3>{principle.title}</h3>
                        <p class="muted">{principle.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- FOOTER LINE -->
    <section class="section--tight divide footer-line-section">
        <div class="wrap wrap--mid">
            <p class="muted footer-line">Techstars Belfast is part of a global movement of Techstars Startup Community Partners, building stronger founder networks in cities around the world.</p>
        </div>
    </section>
</BaseLayout>

<style>
    /* HERO */
    .hero { padding: 6rem 0 4rem; }
    .hero h1 { margin: 1.25rem 0 1rem; }
    .hero-tagline {
        font-family: var(--mono);
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
        margin-bottom: 1.75rem;
    }
    .hero-lead { max-width: 720px; margin-bottom: 1.25rem; }
    .hero-sub { font-size: 1.05rem; margin-bottom: 1.25rem; max-width: 640px; }
    .hero-ethos { font-size: 1.1rem; color: var(--ink-soft); margin-bottom: 2.25rem; }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3.5rem; }

    /* SECTION HEADINGS */
    .section-head { margin: 0.75rem 0 1.5rem; }

    /* WHO ARE TECHSTARS */
    .mission { font-size: 1.05rem; color: var(--ink-soft); margin-top: 1rem; }
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin: 2.25rem 0;
        padding: 1.75rem 0;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
    }
    .stat-item { display: flex; flex-direction: column; gap: 0.2rem; }
    .stat-number { font-family: var(--mono); font-size: 1.4rem; font-weight: 700; color: var(--accent); }
    .stat-label { font-size: 0.85rem; color: var(--ink-muted); }
    .leader-note { font-size: 0.9rem; margin-top: 0.75rem; }

    /* WHAT IS TECHSTARS BELFAST */
    .what-sub { margin-top: 1rem; }
    .stack-label {
        font-family: var(--mono);
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink-muted);
        margin: 2.5rem 0 1.25rem;
        line-height: 1.6;
    }
    .stack-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 2rem; }
    .stack-card { display: flex; align-items: flex-start; gap: 1rem; padding: 1.4rem; }
    .stack-icon {
        width: 40px; height: 40px;
        display: flex; align-items: center; justify-content: center;
        background: var(--accent-soft);
        border-radius: 10px;
        flex-shrink: 0;
    }
    .stack-icon i { width: 20px; height: 20px; color: var(--accent); }
    .stack-text { display: flex; flex-direction: column; gap: 0.25rem; }
    .stack-text strong { font-size: 0.98rem; }
    .stack-text span { font-size: 0.92rem; line-height: 1.5; }
    .flywheel-block { background: var(--accent-soft); border-radius: 16px; padding: 1.5rem 1.75rem; }
    .flywheel-intro { font-size: 0.9rem; color: #0a3d24; margin-bottom: 0.5rem; }
    .flywheel { font-family: var(--mono); font-size: 1rem; font-weight: 700; color: var(--accent); line-height: 1.6; }

    /* OUR DNA */
    .band { background: var(--accent-soft); }
    .dna-headline { margin: 0.75rem 0 0.5rem; color: #0a3d24; }
    .dna-subhead {
        font-size: clamp(1.1rem, 2vw, 1.3rem);
        color: #0a3d24;
        margin-bottom: 2.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid rgba(10, 61, 36, 0.15);
    }
    .dna-values { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem; }
    .value-block p { font-size: 1.05rem; color: #0a3d24; line-height: 1.7; margin-bottom: 1rem; }
    .value-emphasis { font-weight: 600; }

    /* OUR PARTNERS */
    .partners-intro { max-width: 640px; margin-bottom: 2.5rem; }
    .partners-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .partner-photo { width: 100%; aspect-ratio: 3 / 2; object-fit: cover; border-radius: 16px; margin-bottom: 1.25rem; }
    .partner h3 { margin-bottom: 0.75rem; }
    .partner-description { font-size: 0.98rem; line-height: 1.6; margin-bottom: 1rem; }
    .partner-why {
        font-size: 0.93rem;
        color: var(--ink-soft);
        line-height: 1.6;
        padding-top: 1rem;
        border-top: 1px solid var(--line);
    }

    /* WHY NOW */
    .why-lead { margin-bottom: 2.25rem; }
    .why-block { margin-bottom: 2rem; }
    .why-block h3 { font-size: 1.05rem; font-weight: 600; letter-spacing: 0; margin-bottom: 1rem; color: var(--ink-soft); }
    .arrow-list { list-style: none; display: flex; flex-direction: column; gap: 0.65rem; }
    .arrow-list li {
        font-size: 0.98rem;
        color: var(--ink-soft);
        padding-left: 1.5rem;
        position: relative;
        line-height: 1.55;
    }
    .arrow-list li::before { content: "→"; position: absolute; left: 0; color: var(--accent); font-weight: 700; }
    .why-conclusion { font-size: 1.05rem; color: var(--ink-soft); margin: 2rem 0 0.75rem; }
    .why-tagline { font-size: 1.15rem; font-weight: 600; }

    /* HOW TO GET INVOLVED */
    .involved-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 1rem; }
    .involved-card { display: flex; flex-direction: column; align-items: flex-start; }
    .involved-icon {
        width: 48px; height: 48px;
        display: flex; align-items: center; justify-content: center;
        background: var(--accent-soft);
        border-radius: 12px;
        margin-bottom: 1.25rem;
    }
    .involved-icon i { width: 24px; height: 24px; color: var(--accent); }
    .involved-card h3 { font-size: 1.05rem; margin-bottom: 0.65rem; }
    .involved-card p { font-size: 0.95rem; line-height: 1.55; margin-bottom: 1.5rem; }
    .involved-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: auto; }
    .btn--sm { padding: 0.6rem 1.2rem; font-size: 0.85rem; }

    /* PRINCIPLES */
    .principles-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 1rem; }
    .principle-card { border: 1px solid var(--line); border-radius: 16px; padding: 1.5rem; }
    .principle-card h3 { font-size: 1rem; margin-bottom: 0.4rem; }
    .principle-card p { font-size: 0.9rem; line-height: 1.5; }

    /* FOOTER LINE */
    .footer-line-section { background: var(--bg-subtle); }
    .footer-line { text-align: center; font-size: 0.95rem; font-style: italic; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
        .hero-photo { aspect-ratio: 16 / 10; }
        .stats-row { grid-template-columns: repeat(2, 1fr); }
        .stack-grid { grid-template-columns: 1fr; }
        .dna-values { grid-template-columns: 1fr; gap: 1.5rem; }
        .partners-grid { grid-template-columns: 1fr; gap: 2rem; }
        .involved-grid { grid-template-columns: 1fr; }
        .principles-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 600px) {
        .hero-ctas .btn,
        .involved-ctas .btn { width: 100%; }
        .principles-grid { grid-template-columns: 1fr; }
        .stats-row { grid-template-columns: 1fr; gap: 1.25rem; }
    }
</style>
