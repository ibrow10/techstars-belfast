---
import BaseLayout from '../layouts/BaseLayout.astro';
import eventsFeed from '../data/events-feed.json';

// Feed is read-only input regenerated by a sibling system. Do not hand-edit.
const buildDate = new Date();
const today = new Date(buildDate.getFullYear(), buildDate.getMonth(), buildDate.getDate());
const parseEventDate = (isoDate) => {
    const [year, month, day] = isoDate.split('-').map(Number);
    return new Date(year, month - 1, day);
};
const upcomingSprints = eventsFeed
    .filter(e => e.sprint && !e.private && parseEventDate(e.date) >= today)
    .sort((a, b) => parseEventDate(a.date) - parseEventDate(b.date));
const fmtSprintDate = (iso) => parseEventDate(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const examples = [
    {
        partner: 'Sure Valley Ventures',
        title: 'SVV Build Sprint',
        location: 'Belfast',
        description: 'A focused build session with the SVV team and their portfolio: founders, operators, and investors in the same room shipping working prototypes against real challenges.',
        tag: 'FUND PARTNER'
    },
    {
        partner: 'The AMP × Invest NI',
        title: 'AI Build Day, Derry',
        location: 'The AMP Growth Incubator, Derry',
        description: 'A day-long AI build event: morning intro to models and tooling, two-hour afternoon build sprint on workflows, websites, agents or products, ending in a show-and-tell.',
        tag: 'REGIONAL'
    },
    {
        partner: "Queen's University Belfast",
        title: 'HackBelfast 2026',
        location: "Queen's University Belfast",
        description: "Community partner for Northern Ireland's largest student-led hackathon. 175+ students, 24 hours, real-world challenges across Builder, Non-Builder, and Finance tracks.",
        tag: 'COMMUNITY'
    }
];

const openTo = [
    'Universities and research groups',
    'Funds and investors',
    'Corporates and partners',
    'Public sector and government',
    'Community groups and meetups'
];
---

<BaseLayout title="Sprints">
    <!-- Hero -->
    <section class="sprint-hero">
        <div class="hero-bg"></div>
        <div class="container">
            <p class="hero-label">SPRINTS</p>
            <h1>RUN A SPRINT WITH US</h1>
            <p class="hero-tagline">
                Short, high-intensity build sessions where founders, builders, and operators meet a real problem and ship something useful, fast.
            </p>
            <div class="hero-ctas">
                <a href="https://www.linkedin.com/showcase/techstars-belfast" class="btn btn--accent" target="_blank" rel="noopener">Get in touch</a>
                <a href="#examples" class="btn btn--outline">See what we've run</a>
            </div>
        </div>
    </section>

    <!-- What is a Sprint -->
    <section class="what-section">
        <div class="container">
            <p class="lead">
                A Sprint is a time-boxed build, anywhere from a few hours to a few days. People form teams, pick a real problem, build a working prototype, and demo what they shipped. <span class="highlight">Working beats pretty. Shipping beats slides.</span>
            </p>
        </div>
    </section>

    <!-- Upcoming sprints (from the live events feed) -->
    {upcomingSprints.length > 0 && (
        <section class="next-sprint-section">
            <div class="container">
                <div class="section-header">
                    <h2>{upcomingSprints.length > 1 ? 'UPCOMING SPRINTS' : 'NEXT SPRINT'}</h2>
                </div>
                <div class="upcoming-sprints-grid">
                    {upcomingSprints.map(s => (
                        <div class="example-card next-sprint-card">
                            <span class="example-tag">{s.tag}</span>
                            <h3>{s.title}</h3>
                            <p class="example-partner">{fmtSprintDate(s.date)}{s.time ? ` · ${s.time}` : ''} · {s.venue}</p>
                            <p class="example-description">{s.description}</p>
                            {s.link && (
                                <a href={s.link} class="btn btn--accent" target="_blank" rel="noopener">{s.link.includes('qub.ac.uk') ? 'Apply' : 'Register now'}</a>
                            )}
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- Examples -->
    <section id="examples" class="examples-section">
        <div class="container">
            <div class="section-header">
                <h2>SPRINTS WE'VE RUN OR SUPPORTED</h2>
                <p class="section-tagline">A few recent examples.</p>
            </div>
            <div class="examples-grid">
                {examples.map(example => (
                    <div class="example-card">
                        <span class="example-tag">{example.tag}</span>
                        <h3>{example.title}</h3>
                        <p class="example-partner">With {example.partner} · {example.location}</p>
                        <p class="example-description">{example.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Open To -->
    <section class="open-section">
        <div class="container">
            <div class="open-content">
                <h2>OPEN TO RUNNING THESE WITH ANYONE</h2>
                <p class="open-intro">If you've got a real challenge and people willing to build against it, we can help shape a Sprint around it.</p>
                <ul class="open-list">
                    {openTo.map(item => (
                        <li><i data-lucide="check"></i>{item}</li>
                    ))}
                </ul>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="final-cta-section">
        <div class="container">
            <div class="final-cta-block">
                <h2>WANT TO RUN ONE?</h2>
                <p class="final-cta-tagline">Drop us a line on LinkedIn and we'll set it up.</p>
                <a href="https://www.linkedin.com/showcase/techstars-belfast" class="btn btn--accent" target="_blank" rel="noopener">Get in touch</a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* HERO */
    .sprint-hero {
        padding-top: 160px;
        padding-bottom: 5rem;
        border-bottom: 1px solid var(--border-color);
        position: relative;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background-image: url('/images/fc.jpg');
        background-size: cover;
        background-position: center;
        opacity: 0.15;
        z-index: 0;
    }

    .hero-bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(15, 15, 15, 0.3) 0%, rgba(15, 15, 15, 0.9) 70%, rgba(15, 15, 15, 1) 100%);
    }

    .sprint-hero .container {
        max-width: 900px;
        position: relative;
        z-index: 1;
    }

    .hero-label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent-color);
        margin-bottom: 1rem;
    }

    .sprint-hero h1 {
        font-size: clamp(2.5rem, 7vw, 4.5rem);
        margin-bottom: 1.5rem;
        line-height: 1;
    }

    .hero-tagline {
        font-size: clamp(1.15rem, 2.2vw, 1.4rem);
        color: #ccc;
        max-width: 720px;
        line-height: 1.5;
        margin-bottom: 2.5rem;
    }

    .hero-ctas {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn--outline {
        background: transparent;
        color: var(--text-color);
    }

    .btn--outline:hover {
        background: var(--text-color);
        color: var(--bg-color);
    }

    .btn--accent {
        background: var(--accent-color);
        color: var(--bg-color);
        border-color: var(--accent-color);
    }

    .btn--accent:hover {
        background: transparent;
        color: var(--accent-color);
    }

    /* WHAT */
    .what-section {
        padding: 4rem 0;
        border-bottom: 1px solid var(--border-color);
    }

    .what-section .container {
        max-width: 800px;
    }

    .what-section .lead {
        font-size: 1.25rem;
        color: #ccc;
        line-height: 1.6;
    }

    .what-section .highlight {
        color: var(--accent-color);
        font-weight: 500;
    }

    /* EXAMPLES */
    .examples-section {
        padding: 5rem 0;
        border-bottom: 1px solid var(--border-color);
        background: #0a0a0a;
    }

    .examples-section .container {
        max-width: 1000px;
    }

    .section-header {
        margin-bottom: 2.5rem;
    }

    .section-header h2 {
        margin-bottom: 0.5rem;
    }

    .section-tagline {
        font-size: 1.1rem;
        color: var(--text-muted);
    }

    .examples-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .example-card {
        padding: 2rem;
        background: #161616;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .example-card:hover {
        border-color: var(--accent-color);
        transform: translateY(-2px);
    }

    .example-tag {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--accent-color);
        background: rgba(0, 230, 118, 0.1);
        padding: 4px 10px;
        border-radius: 20px;
        align-self: flex-start;
        letter-spacing: 0.05em;
    }

    .example-card h3 {
        font-size: 1.25rem;
        margin: 0.5rem 0 0;
        text-transform: none;
        font-family: var(--font-main);
        color: #fff;
    }

    .example-partner {
        font-size: 0.85rem;
        color: var(--accent-color);
        font-family: var(--font-mono);
        margin: 0;
    }

    .example-description {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0.5rem 0 0;
    }

    /* OPEN TO */
    .open-section {
        padding: 5rem 0;
        border-bottom: 1px solid var(--border-color);
    }

    .open-section .container {
        max-width: 800px;
    }

    .open-content h2 {
        margin-bottom: 1rem;
    }

    .open-intro {
        font-size: 1.1rem;
        color: #ccc;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .open-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 0.75rem;
    }

    .open-list li {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1rem;
        color: #ccc;
        padding: 0.75rem 1rem;
        background: #161616;
        border: 1px solid var(--border-color);
        border-radius: 8px;
    }

    .open-list i {
        width: 18px;
        height: 18px;
        color: var(--accent-color);
        flex-shrink: 0;
    }

    /* FINAL CTA */
    .final-cta-section {
        padding: 5rem 0;
    }

    .final-cta-section .container {
        max-width: 800px;
    }

    .final-cta-block {
        text-align: center;
        padding: 4rem;
        background: linear-gradient(135deg, rgba(0, 230, 118, 0.08) 0%, transparent 50%);
        border: 1px solid var(--border-color);
        border-radius: 16px;
    }

    .final-cta-block h2 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .final-cta-tagline {
        font-size: 1.2rem;
        color: #aaa;
        margin-bottom: 2rem;
    }

    /* RESPONSIVE */
    @media (max-width: 768px) {
        .sprint-hero {
            padding-top: 120px;
            padding-bottom: 3rem;
        }

        .hero-ctas {
            flex-direction: column;
        }

        .hero-ctas .btn {
            width: 100%;
            text-align: center;
        }

        .final-cta-block {
            padding: 2rem;
        }

        .final-cta-block h2 {
            font-size: 2rem;
        }
    }

    .next-sprint-section {
        padding: 4rem 0 1rem;
    }
    .next-sprint-card {
        border-color: var(--accent-color);
    }
    .next-sprint-card .btn {
        margin-top: 1.25rem;
    }
    .upcoming-sprints-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
    }
</style>
