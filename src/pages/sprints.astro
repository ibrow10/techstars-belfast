---
import BaseLayout from '../layouts/BaseLayout.astro';
import eventsFeed from '../data/events-feed.json';

// Feed is read-only input regenerated by a sibling system. Do not hand-edit.
const buildDate = new Date();
const today = new Date(buildDate.getFullYear(), buildDate.getMonth(), buildDate.getDate());
const parseEventDate = (isoDate) => {
    const [year, month, day] = isoDate.split('-').map(Number);
    return new Date(year, month - 1, day);
};
const upcomingSprints = eventsFeed
    .filter(e => e.sprint && !e.private && parseEventDate(e.date) >= today)
    .sort((a, b) => parseEventDate(a.date) - parseEventDate(b.date));
const fmtSprintDate = (iso) => parseEventDate(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const examples = [
    {
        partner: 'Sure Valley Ventures',
        title: 'SVV Build Sprint',
        location: 'Belfast',
        description: 'A focused build session with the SVV team and their portfolio: founders, operators, and investors in the same room shipping working prototypes against real challenges.',
        tag: 'FUND PARTNER'
    },
    {
        partner: 'The AMP × Invest NI',
        title: 'AI Build Day, Derry',
        location: 'The AMP Growth Incubator, Derry',
        description: 'A day-long AI build event: morning intro to models and tooling, two-hour afternoon build sprint on workflows, websites, agents or products, ending in a show-and-tell.',
        tag: 'REGIONAL'
    },
    {
        partner: "Queen's University Belfast",
        title: 'HackBelfast 2026',
        location: "Queen's University Belfast",
        description: "Community partner for Northern Ireland's largest student-led hackathon. 175+ students, 24 hours, real-world challenges across Builder, Non-Builder, and Finance tracks.",
        tag: 'COMMUNITY'
    }
];

---

<BaseLayout title="Sprints" description="Short, high-intensity build sessions. Run one with Techstars Belfast: open to universities, funds, corporates and the public sector.">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Sprints</p>
            <h1>Run a sprint <span class="accent">with us.</span></h1>
            <p class="lead hero-lead">
                Short, high-intensity build sessions where founders, builders, and operators meet a real problem and ship something useful, fast.
            </p>
            <div class="hero-ctas">
                <a href="/contact" class="btn btn--accent">Get in touch</a>
                <a href="#examples" class="btn btn--ghost">See what we've run</a>
            </div>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-348.jpg" alt="Teams building together at a Techstars Belfast sprint" class="hero-photo" />
        </div>
    </section>

    <!-- WHAT IS A SPRINT -->
    <section class="section--tight band divide">
        <div class="wrap wrap--mid">
            <p class="band-line">
                A Sprint is a time-boxed build, anywhere from a few hours to a few days. People form teams, pick a real problem, build a working prototype, and demo what they shipped. <span class="highlight">Working beats pretty. Shipping beats slides.</span>
            </p>
        </div>
    </section>

    <!-- Upcoming sprints (from the live events feed) -->
    {upcomingSprints.length > 0 && (
        <section class="section--tight">
            <div class="wrap">
                <h2 class="sprints-head">{upcomingSprints.length > 1 ? 'Upcoming sprints' : 'Next sprint'}</h2>
                <div class="upcoming-grid">
                    {upcomingSprints.map(s => (
                        <div class="card sprint-card">
                            <span class="tag-chip">{s.tag}</span>
                            <h3>{s.title}</h3>
                            <p class="meta-line">{fmtSprintDate(s.date)}{s.time ? ` · ${s.time}` : ''} · {s.venue}</p>
                            <p class="muted card-description">{s.description}</p>
                            {s.link && (
                                <a href={s.link} class="btn btn--accent sprint-btn" target="_blank" rel="noopener">{s.link.includes('qub.ac.uk') ? 'Apply' : 'Register now'}</a>
                            )}
                        </div>
                    ))}
                </div>
            </div>
        </section>
    )}

    <!-- EXAMPLES -->
    <section id="examples" class="section divide">
        <div class="wrap">
            <p class="eyebrow">A few recent examples</p>
            <h2 class="examples-head">Sprints we've run or supported</h2>
            <div class="examples-grid">
                {examples.map((example, i) => {
                    const photo = [
                        { src: '/images/photos/pic-282.jpg', alt: 'Teams working together at the SVV Build Sprint' },
                        { src: '/images/photos/pic-149.jpg', alt: 'Builders in discussion at the AI Build Day in Derry' },
                        { src: '/images/photos/pic-283.jpg', alt: 'Student builders demoing at HackBelfast' },
                    ][i];
                    return (
                        <div class="card example-card">
                            <img src={photo.src} alt={photo.alt} class="example-photo" loading="lazy" />
                            <span class="tag-chip">{example.tag}</span>
                            <h3>{example.title}</h3>
                            <p class="meta-line">With {example.partner} · {example.location}</p>
                            <p class="muted card-description example-description">{example.description}</p>
                        </div>
                    );
                })}
            </div>
        </div>
    </section>

    <!-- FINAL CTA -->
    <section class="cta-band">
        <div class="wrap wrap--mid cta-inner">
            <h2>Want to run one?</h2>
            <p class="lead">Tell us what you have in mind and we'll set it up.</p>
            <a href="/contact" class="btn btn--accent">Get in touch</a>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 3.5rem; }
    .hero h1 { margin: 1.25rem 0 1.5rem; }
    .hero-lead { max-width: 620px; margin-bottom: 2.25rem; }
    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3rem; }

    /* WHAT IS A SPRINT */
    .band { background: var(--accent-soft); }
    .band-line { font-size: clamp(1.3rem, 2.6vw, 1.8rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.4; color: #0a3d24; }
    .band-line .highlight { color: var(--accent); }

    /* SHARED CARD BITS */
    .tag-chip {
        font-family: var(--mono);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
        background: var(--accent-soft);
        padding: 4px 10px;
        border-radius: 999px;
        align-self: flex-start;
    }
    .meta-line { font-family: var(--mono); font-size: 0.8rem; color: var(--ink-muted); margin: 0; }
    .card-description { font-size: 0.95rem; line-height: 1.55; margin-top: 0.5rem; }

    /* UPCOMING SPRINTS */
    .sprints-head { margin-bottom: 2rem; }
    .upcoming-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; }
    .sprint-card { display: flex; flex-direction: column; gap: 0.5rem; }
    .sprint-card h3 { margin: 0.6rem 0 0; }
    .sprint-btn { margin-top: 1.25rem; align-self: flex-start; }

    /* EXAMPLES */
    .examples-head { margin: 0.75rem 0 2.5rem; }
    .examples-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .example-card { display: flex; flex-direction: column; gap: 0.5rem; overflow: hidden; padding: 0; }
    .example-card > * { margin-left: 2rem; margin-right: 2rem; }
    .example-card .example-photo { margin: 0 0 1.5rem; width: 100%; aspect-ratio: 3 / 2; object-fit: cover; }
    .example-card h3 { margin: 0.6rem 0 0; }
    .example-card .example-description { margin-bottom: 2rem; }

    /* CTA BAND */
    .cta-band { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .cta-band h2 { color: var(--bg); }
    .cta-band .lead { color: rgba(255,255,255,0.72); }

    @media (max-width: 900px) {
        .hero-photo { aspect-ratio: 16 / 10; }
        .examples-grid { grid-template-columns: 1fr; }
        .upcoming-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
        .hero-ctas .btn { width: 100%; text-align: center; justify-content: center; }
        .sprint-btn { width: 100%; align-self: stretch; text-align: center; justify-content: center; }
    }
</style>
