---
import BaseLayout from '../layouts/BaseLayout.astro';

const examples = [
    { tag: 'Fund partner', title: 'SVV Build Sprint', with: 'Sure Valley Ventures · Belfast', body: 'Founders, operators and investors in one room, shipping working prototypes against real challenges.', img: '/images/photos/pic-282.jpg', alt: 'Teams working together at the SVV build sprint' },
    { tag: 'Regional', title: 'AI Build Day, Derry', with: 'The AMP × Invest NI · Derry', body: 'Morning intro to models and tooling, an afternoon build sprint, ending in a show-and-tell.', img: '/images/photos/pic-149.jpg', alt: 'Builders in discussion at an AI build day workshop table' },
    { tag: 'Community', title: 'HackBelfast 2026', with: "Queen's University Belfast", body: "Community partner for NI's largest student-led hackathon. 175+ students, 24 hours, real challenges.", img: '/images/photos/pic-283.jpg', alt: 'Two student builders demoing from a laptop' },
];

const openTo = [
    'Universities and research groups',
    'Funds and investors',
    'Corporates and partners',
    'Public sector and government',
    'Community groups and meetups',
];
---

<BaseLayout title="Sprints" description="Short, high-intensity build sessions. Run one with Techstars Belfast — open to universities, funds, corporates and the public sector.">
    <!-- HERO -->
    <section class="hero">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Sprints</p>
            <h1>Run a sprint <span class="accent">with us.</span></h1>
            <p class="lead hero-lead">
                Short, high-intensity build sessions where founders, builders and operators
                meet a real problem and ship something useful — fast. We build them with you,
                around your challenge.
            </p>
            <a href="#talk" class="btn btn--accent">Let's run one</a>
        </div>
        <div class="wrap">
            <img src="/images/photos/pic-348.jpg" alt="Teams building together at a Techstars Belfast sprint" class="hero-photo" />
        </div>
    </section>

    <!-- WHAT -->
    <section class="section--tight band divide">
        <div class="wrap wrap--mid">
            <p class="band-line">
                A sprint is a time-boxed build — a few hours to a few days. Teams form, pick a real
                problem, build a working prototype, and demo it. <span class="accent">Working beats pretty. Shipping beats slides.</span>
            </p>
        </div>
    </section>

    <!-- EXAMPLES -->
    <section class="section">
        <div class="wrap">
            <p class="eyebrow">A few we've run</p>
            <h2 class="ex-head">Built with partners across NI.</h2>
            <div class="ex-grid">
                {examples.map(e => (
                    <div class="card ex-card">
                        <img src={e.img} alt={e.alt} class="ex-photo" loading="lazy" />
                        <span class="ex-tag">{e.tag}</span>
                        <h3>{e.title}</h3>
                        <p class="ex-with">{e.with}</p>
                        <p class="muted ex-body">{e.body}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- OPEN TO -->
    <section class="section divide">
        <div class="wrap wrap--mid">
            <p class="eyebrow">Who we'll build with</p>
            <h2 class="open-head">Got a real challenge and people to build against it? We're in.</h2>
            <div class="open-grid">
                {openTo.map(o => <span class="open-pill">{o}</span>)}
            </div>
        </div>
    </section>

    <!-- TALK -->
    <section id="talk" class="talk">
        <div class="wrap wrap--mid talk-inner">
            <h2>Let's shape one together.</h2>
            <p class="lead">Tell us the problem. We'll help design the sprint around it.</p>
            <a href="https://www.linkedin.com/showcase/techstars-belfast" class="btn btn--accent" target="_blank" rel="noopener">Get in touch</a>
        </div>
    </section>
</BaseLayout>

<style>
    .hero { padding: 6rem 0 4rem; }
    .hero h1 { margin: 1.25rem 0 1.75rem; }
    .hero-lead { margin-bottom: 2.5rem; }
    .hero-photo { width: 100%; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 20px; margin-top: 3.5rem; }

    .band { background: var(--accent-soft); }
    .band-line { font-size: clamp(1.3rem, 2.6vw, 1.8rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.4; color: #0a3d24; }
    .band-line .accent { color: var(--accent); }

    .ex-head, .open-head { margin: 0.75rem 0 2.5rem; }
    .open-head { max-width: 18ch; }
    .ex-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .ex-card { display: flex; flex-direction: column; gap: 0.4rem; overflow: hidden; padding: 0; }
    .ex-card > * { margin-left: 2rem; margin-right: 2rem; }
    .ex-card .ex-photo { margin: 0 0 1.5rem; width: 100%; aspect-ratio: 3 / 2; object-fit: cover; }
    .ex-card .ex-body { margin-bottom: 2rem; }
    .ex-tag { font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); background: var(--accent-soft); padding: 4px 10px; border-radius: 999px; align-self: flex-start; margin-left: 2rem; }
    .ex-card h3 { margin: 0.6rem 0 0; }
    .ex-with { font-family: var(--mono); font-size: 0.8rem; color: var(--ink-muted); }
    .ex-body { margin-top: 0.5rem; font-size: 0.95rem; }

    .open-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; }
    .open-pill { font-size: 0.98rem; padding: 0.7rem 1.2rem; border: 1px solid var(--line); border-radius: 999px; color: var(--ink-soft); }

    .talk { background: var(--ink); color: var(--bg); padding: 6rem 0; }
    .talk-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; }
    .talk h2 { color: var(--bg); }
    .talk .lead { color: rgba(255,255,255,0.72); }

    @media (max-width: 900px) {
        .ex-grid { grid-template-columns: 1fr; }
        .hero-photo { aspect-ratio: 16 / 10; }
    }
</style>
